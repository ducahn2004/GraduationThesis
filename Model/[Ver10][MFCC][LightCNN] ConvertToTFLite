es[i].numpy()\n","\n","            # QUAN TRỌNG: Không dùng .T nếu mô hình PyTorch của bạn nhận (39, 333)\n","            x_input = np.expand_dims(x, axis=0).astype(np.float32)\n","\n","            # Chạy inference\n","            outputs = session.run(None, {input_name: x_input})\n","            logits = outputs[0][0] # Lấy kết quả mẫu đầu tiên trong batch\n","\n","            gt = int(labels[i].item())\n","            pred = int(np.argmax(logits))\n","\n","            if pred == gt:\n","                correct += 1\n","\n","            # Tính Confusion Matrix\n","            if gt == 1 and pred == 1: TP += 1\n","            elif gt == 0 and pred == 0: TN += 1\n","            elif gt == 0 and pred == 1: FP += 1\n","            elif gt == 1 and pred == 0: FN += 1\n","\n","            total += 1\n","\n","    acc = correct / total if total > 0 else 0\n","    sen = TP / (TP + FN) if (TP + FN) > 0 else 0\n","    spe = TN / (TN + FP) if (TN + FP) > 0 else 0\n","\n","    print(f\"Kết quả {name}:\")\n","    print(f\"  Accuracy    : {acc*100:.2f}%\")\n","    print(f\"  Sensitivity : {sen*100:.2f}% (TP={TP}, FN={FN})\")\n","    print(f\"  Specificity : {spe*100:.2f}% (TN={TN}, FP={FP})\")\n","\n","    return sen"],"metadata":{"id":"rDMMx7mexxUa","executionInfo":{"status":"ok","timestamp":1776084362879,"user_tz":-420,"elapsed":8,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}}},"execution_count":43,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 1. KHỞI TẠO DATALOADER CHO TẬP INTERNAL VALIDATION\n","# ============================================================\n","val_internal_path = DATASET_PATH / \"mfcc_39_val_internal.h5\"\n","val_internal_label = DATASET_PATH / \"label_39_val_clean.csv\"\n","\n","# Lấy danh sách keys từ file h5\n","with h5py.File(val_internal_path, 'r') as hf:\n","    val_internal_keys = list(hf.keys())\n","\n","val_internal_dataset = MFCCDataset(\n","    features_h5_path=