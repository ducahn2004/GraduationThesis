unc=self._run_torch,\n","            inp=[x],\n","            Tout=tf.float32\n","        )\n","        output.set_shape([1, 2])\n","        return output\n","\n","    def _run_torch(self, x_np):\n","        \"\"\"Chạy TorchScript model; gọi từ tf.numpy_function.\"\"\"\n","        with torch.no_grad():\n","            t = torch.from_numpy(x_np)          # (1, 39, 333) float32\n","            y = self._ts_model(t)                # (1, 2)\n","        return y.numpy().astype(np.float32)\n","\n","\n","tf_module = TorchToTFModule(traced)\n","\n","# ── Bước 3: Lưu SavedModel ───────────────────────────────────────────────────\n","SAVED_MODEL_DIR = str(TFLITE_DIR / f\"{MODEL_NAME.lower()}_{TIMESTAMP}_saved_model\")\n","tf.saved_model.save(tf_module, SAVED_MODEL_DIR)\n","print(f\"✅ SavedModel lưu tại: {SAVED_MODEL_DIR}\")\n","\n","\"\"\"# [MỚI] TFLiteConverter — Integer with Float Fallback (INT8 PTQ)\"\"\"\n","# ════════════════════════════════════════════════════════════════════════════\n","# Đây là phần THAY THẾ trực tiếp khối onnx2tf.convert(...) của Ver10.\n","#\n","# Phương pháp: \"Integer with float fallback\"\n","#   - Toàn bộ model được quantize sang INT8.\n","#   - Nếu một op không có implementation INT8 (hiếm), TFLite sẽ dùng float32.\n","#   - Input / Output giữ nguyên float32 → không cần quantize/dequantize thủ công\n","#     khi chạy inference (giống behavior của onnx2tf với input_quant_dtype=\"float32\").\n","# ════════════════════════════════════════════════════════════════════════════\n","\n","calib_data = np.load(\"calib_tflite_float32.npy\")   # (N, 39, 333) float32\n","\n","# ── Representative dataset generator ────────────────────────────────────────\n","def representative_dataset():\n","    \"\"\"\n","    Generator trả về từng sample cho TFLiteConverter.\n","    Mỗi yield là list chứa 1 tensor shape (1, 39, 333) float32.\n","    Số lượng khuyến nghị: 100–300 mẫu đa dạng (normal + abnormal).\n","    \"\"\"\n","    for i in range(len(calib_data)):\n","        sample = calib_data[i:i+1].astype(np.float32)  # (1, 39, 333)\n","        yield [sample]\n","\n","# ── Khởi tạo converter ───────────────────────────────────────────────────────\n","converter = tf.lite.TFLiteConverter.from_saved_model(SAVED_MODEL_DIR)\n","\n","# ── Bật INT8 optimization ─────────────────────────────────────────────────────\n","converter.optimizations = [tf.lite.Optimize.DEFAULT]\n","\n","# ── Cung cấp dữ liệu calibration để tính scale/zero_point của mỗi tensor ─────\n","converter.representative_dataset = representative_dataset\n","\n","# ── (Tùy chọn) Ép buộc input/output ops phải là float32 ─────────────────────\n","# Dòng dưới đảm bảo I/O là float32 (không cần quantize thủ công khi inference).\n","# Bỏ 2 dòng này nếu muốn full INT8 I/O (hiệu năng cao hơn nhưng cần pre/post-quant).\n","converter.target_spec.supported_ops = [\n","    tf.lite.OpsSet.TFLITE_BUILTINS_INT8,   # ưu tiên INT8 kernel\n","    tf.lite.OpsSet.TFLITE_BUILTINS,        # float fallback cho op không có INT8 impl\n","]\n","converter.inference_input_type  = tf.float32   # float input  → không cần quantize input\n","converter.inference_output_type = tf.float32   # float output → không cần dequantize output\n","\n","# ── Convert ───────────────────────────────────────────────────────────────────\n","print(\"⏳ Đang convert sang TFLite INT8...\")\n","tflite_quant_model = converter.convert()\n","print(\"✅ Convert thành công!\")\n","\n","# ── Lưu file .tflite ──────────────────────────────────────────────────────────\n","OUTPUT_TFLITE_DIR = TFLITE_DIR / f\"{MODEL_NAME.lower()}_tflite_int8_{TIMESTAMP}\"\n","OUTPUT_TFLITE_DIR.mkdir(parents=True, exist_ok=True)\n","\n","int8_tflite_path = OUTPUT_TFLITE_DIR / f\"{MODEL_NAME.lower()}_{TIMESTAMP}_int8_float_io.tflite\"\n","with open(int8_tflite_path, \"wb\") as f:\n","    f.write(tflite_quant_model)\n","\n","size_kb = int8_tflite_path.stat().st_size / 1024\n","print(f\"✅ Đã lưu TFLite tại: {int8_tflite_path}\")\n","print(f\"   Kích thước        : {size_kb:.1f} KB\")\n","\n","# ── Kiểm tra nhanh I/O details ────────────────────────────────────────────────\n","interp = tf.lite.Interpreter(model_path=str(int8_tflite_path), experimental_delegates=[])\n","interp.allocate_tensors()\n","inp_det = interp.get_input_details()[0]\n","out_det = interp.get_output_details()[0]\n","print(f\"\\nInput  dtype={inp_det['dtype'].__name__}  shape={inp_det['shape']}\")\n","print(f\"       scale={inp_det['quantization'][0]:.6f}  zp={inp_det['quantization'][1]}\")\n","print(f\"Output dtype={out_det['dtype'].__name__}  scale={out_det['quantization'][0]:.6f}\")\n","# Kỳ vọng: dtype=float32, scale=0 → I/O float, weights đã INT8"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":876},"id":"qZx2Dle8cSC9","executionInfo":{"status":"error","timestamp":1776084479716,"user_tz":-420,"elapsed":4989,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"b4e5e0db-e172-4fc0-b272-f19c086c6ece"},"execution_count":53,"outputs":[{"output_type":"stream","name":"stdout","text":["Đang dùng model trong memory (Option A)\n","✅ TorchScript trace thành công\n","✅ SavedModel lưu tại: /content/drive/MyDrive/AutomaticHeartSoundClassification-main/TFLITE/light_cnn_0406_135605_saved_model\n","⏳ Đang convert sang TFLite INT8...\n"]},{"output_type":"error","ename":"ConverterError","evalue":"Could not translate MLIR to FlatBuffer.<unknown>:0: error: loc(callsite(callsite(fused[\"PyFunc:\", \"PyFunc@__inference___call___5\"] at fused[\"StatefulPartitionedCall:\", \"StatefulPartitionedCall@__inference_signature_wrapper_11\"]) at fused[\"StatefulPartitionedCall:\", \"StatefulPartitionedCall\"])): 'tf.PyFunc' op is neither a custom op nor a flex op\n<unknown>:0: note: loc(fused[\"StatefulPartitionedCall:\", \"StatefulPartitionedCall\"]): called from\n<unknown>:0: note: loc(callsite(callsite(fused[\"PyFunc:\", \"PyFunc@__inference___call___5\"] at fused[\"StatefulPartitionedCall:\", \"StatefulPartitionedCall@__inference