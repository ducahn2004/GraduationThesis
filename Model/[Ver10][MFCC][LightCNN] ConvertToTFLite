(48, 64, kernel_size=(1, 1), stride=(1, 1), bias=False)\n","    (bn): BatchNorm2d(64, eps=1e-05, momentum=0.1, affine=True, track_running_stats=True)\n","    (act): ReLU6(inplace=True)\n","  )\n","  (se): LiteSEBlock(\n","    (gap): AdaptiveAvgPool2d(output_size=1)\n","    (fc): Sequential(\n","      (0): Linear(in_features=64, out_features=8, bias=True)\n","      (1): ReLU(inplace=True)\n","      (2): Linear(in_features=8, out_features=64, bias=True)\n","      (3): Sigmoid()\n","    )\n","  )\n","  (head): Sequential(\n","    (0): AdaptiveAvgPool2d(output_size=1)\n","    (1): Flatten(start_dim=1, end_dim=-1)\n","    (2): Dropout(p=0.3, inplace=False)\n","    (3): Linear(in_features=64, out_features=2, bias=True)\n","  )\n",")"]},"metadata":{},"execution_count":29}],"source":["checkpoint = torch.load(model_path, map_location=device, weights_only=False)\n","state_dict = checkpoint.get('state_dict', checkpoint)\n","model.load_state_dict(state_dict)\n","model.to(device)\n","model.eval()"]},{"cell_type":"markdown","metadata":{"id":"MA2a4z-V5eou"},"source":["# Punning"]},{"cell_type":"code","execution_count":30,"metadata":{"id":"kTLzc77p5IVi","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776084069330,"user_tz":-420,"elapsed":233,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"05d33103-18ec-4d4b-c30f-26edcb288b1b"},"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Đã apply pruning (với mask)\n"]}],"source":["import torch.nn.utils.prune as prune\n","\n","parameters_to_prune = []\n","for name, module in model.named_modules():\n","    if isinstance(module, (torch.nn.Conv2d, torch.nn.Linear)):\n","        parameters_to_prune.append((module, 'weight'))\n","        # Optional: prune bias too\n","        # if module.bias is not None:\n","        #     parameters_to_prune.append((module, 'bias'))\n","\n","prune.global_unstructured(\n","    parameters_to_prune,\n","    pruning_method=prune.L1Unstructured,\n","    amount=0.2,\n",")\n","\n","print(\"✅ Đã apply pruning (với mask)\")"]},{"cell_type":"code","execution_count":31,"metadata":{"id":"-i4lG_4VAxJn","executionInfo":{"status":"ok","timestamp":1776084069381,"user_tz":-420,"elapsed":21,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}}},"outputs":[],"source":["import librosa, random, numpy as np\n","import torch, torch.nn.functional as F\n","from torch.utils.data import Dataset, DataLoader\n","\n","EPS = 1e-8\n","FIXED_LENGTH = 333\n","def standard_normal_variate(data):\n","    \"\"\"Z-score normalization trên toàn bộ feature\"\"\"\n","    mean = np.mean(data)\n","    std = np.std(data) + EPS\n","    return (data - mean) / std\n","\n","class MFCCDataset(Dataset):\n","    def __init__(self, features_h5_path, label_csv_path, keys=None,\n","                 norm=True, duration=5, hop_length=15, training=False):\n","        self.features_h5_path = features_h5_path\n","        self.labels_df = pd.read_csv(label_csv_path)\n","\n","        # Tạo mapping để tra cứu nhãn nhanh\n","        self.key_to_label = dict(\n","            zip(self.labels_df.iloc[:, 0].apply(lambda x: Path(x).stem if '/' in str(x) else str(x)),\n","                self.labels_df.iloc[:, 1])\n","        )\n","\n","        with h5py.File(features_h5_path, 'r') as hf:\n","            available_keys = set(hf.keys())\n","            if keys is None:\n","                # Nếu không truyền keys, mặc định lấy hết\n","                self.keys = [k for k in available_keys if k in self.key_to_label]\n","            else:\n","                # Chỉ lấy những keys vừa tồn tại trong file H5 vừa có nhãn\n","                self.keys = [k for k in keys if k in available_keys and k in self.key_to_label]\n","\n","        self.norm = norm\n","        self.training = training\n","        self.fixed_length = int(duration * 1000 / hop_length)\n","        self._hf = None\n","\n","    def _get_hf(self):\n","        if self._hf is None:\n","            self._hf = h5py.File(self.features_h5_path, 'r')\n","        return self._hf\n","\n","    def __len__(self):\n","        return len(self.keys)\n","\n","    def __getitem__(self, idx):\n","        key = self.keys[idx]\n","        mfcc = self._get_hf()[key][()].astype(np.float32)\n","\n","        if self.norm:\n","            mfcc = standard_normal_variate(mfcc)\n","\n","        n_mfcc, T = mfcc.shape\n","        if T >= self.fixed_length:\n","            start = (T - self.fixed_length) // 2\n","            mfcc = mfcc[:, start:start + self.fixed_length]\n","        else:\n","            mfcc = np.pad(mfcc, ((0, 0), (0, self.fixed_length - T)), mode=\"constant\")\n","\n","        return (\n","            torch.from_numpy(mfcc),\n","            torch.tensor(self.key_to_label.get(key, 0), dtype=torch.long)\n","        )\n","\n","    def close(self):\n","        if self._hf is not None:\n","            self._hf.close()\n","            self._hf = None"]},{"cell_type":"code","source":["import h5py\n","print(h5py.__version__)"],"metadata":{"id":"WjJ2ONv9SQG3","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776084069396,"user_tz":-420,"elapsed":10,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"d7767f6a-51fc-4e80-e558-a68dde6774d8"},"execution_count":32,"outputs":[{"output_type":"stream","name":"stdout","text":["3.11.0\n"]}]},{"cell_type":"code","execution_count":33,"metadata":{"id":"y_LClACDJrZE","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776084079718,"user_tz":-420,"elapsed":10320,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"95de6157-90c2-454b-c8f3-af109cee85f5"},"outputs":[{"output_type":"stream","name":"stdout","text":["Train: 3656 samples | Val: 648 samples\n","Balanced: 1596 sample/case.  Total: 3656\n"]}],"source":["TRAIN_H5  = DATASET_PATH / \"mfcc_39_train.h5\"\n","TRAIN_CSV = DATASET_PATH / \"label_39_train_augmented.csv\"\n","VAL_H5    = DATASET_PATH / \"mfcc_39_val_internal.h5\"\n","VAL_CSV   = DATASET_PATH / \"label_39_val_clean.csv\"\n","\n","\n","'''\n","train_dataset = MFCCDataset(TRAIN_H5, TRAIN_CSV, training=True)\n","val_dataset   = MFCCDataset(VAL_H5,   VAL_CSV,   training=False)\n","train_loader  = DataLoader(train_dataset, batch_size=64, shuffle=True,  num_workers=2, pin_memory=True)\n","val_loader    = DataLoader(val_dataset,   batch_size=64, shuffle=False, num_workers=2, pin_memory=True)\n","'''\n","\n","# Đọc file label để phân loại keys\n","labels_df = pd.read_csv(TRAIN_CSV)\n","# Chuẩn hóa tên file (stem) để khớp với key trong H5\n","labels_df['stem'] = labels_df.iloc[:, 0].apply(lambda x: Path(x).stem)\n","\n","# Tách keys theo nhãn\n","keys_normal = labels_df[labels_df.iloc[:, 1] == 0]['stem'].values\n","keys_abnormal = labels_df[labels_df.iloc[:, 1] == 1]['stem'].values\n","\n","# Lấy số lượng mẫu bằng với số lượng của lớp ít hơn (thường là Abnormal)\n","num_samples_per_class = min(len(keys_normal), len(keys_abnormal))\n","\n","\n","balanced_normal = np.random.choice(keys_normal, num_samples_per_class, replace=False)\n","balanced_abnormal = np.random.choice(keys_abnormal, num_samples_per_class, replace=False)\n","\n","# Lấy mẫu ngẫu nhiên hoặc lấy đầu danh sách để cân bằng\n","balanced_keys = np.concatenate([balanced_normal, balanced_abnormal])\n","np.random.shuffle(balanced_keys) # Trộn đều nhãn\n","\n","train_dataset = MFCCDataset(TRAIN_H5, TRAIN_CSV, training=True)   # keys=None → tự lấy từ TRAIN_H5\n","val_dataset   = MFCCDataset(VAL_H5,   VAL_CSV,   training=False)  # keys=None → tự lấy từ VAL_H5\n","\n","print(f\"Train: {len(train_dataset)} samples | Val: {len(val_dataset)} samples\")\n","print(f\"Balanced: {num_samples_per_class} sample/case.  Total: {len(train_dataset)}\")\n","\n","train_loader = DataLoader(train_dataset, batch_size=64, shuffle=True,\n","                          num_workers=2, pin_memory=True)\n","val_loader   = DataLoader(val_dataset,   batch_size=64, shuffle=False,\n","                          num_workers=2, pin_memory=True)"]},{"cell_type":"code","source":["criterion = AsymmetricFocalLoss(\n","    gamma_pos=0.5,    # Giữ sensitivity cao cho lớp Abnormal\n","    gamma_neg=2.0,    # Phạt nặng False Positive (nhãn Normal bị đoán sai)\n","    label_smoothing=0.05\n",")"],"metadata":{"id":"XgC23eDybMd8","executionInfo":{"status":"ok","timestamp":1776084079762,"user_tz":-420,"elapsed":41,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}}},"execution_count":34,"outputs":[]},{"cell_type":"code","execution_count":35,"metadata":{"id":"ZKkKmnOR5Pwt","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776084300913,"user_tz":-420,"elapsed":221133,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"557abcf0-363e-4280-8b09-5a8c0c9eff94"},"outputs":[{"output_type":"stream","name":"stdout","text":["Fine-tune Epoch 1/50 - Avg Loss: 0.121057\n","Fine-tune Epoch 2/50 - Avg Loss: 0.107633\n","Fine-tune Epoch 3/50 - Avg Loss: 0.100909\n","Fine-tune Epoch 4/50 - Avg Loss: 0.093759\n","Fine-tune Epoch 5/50 - Avg Loss: 0.091649\n","   >>> Val Accuracy sau epoch 5: 0.8981\n","Fine-tune Epoch 6/50 - Avg Loss: 0.093496\n","Fine-tune Epoch 7/50 - Avg Loss: 0.089710\n","Fine-tune Epoch 8/50 - Avg Loss: 0.085830\n","Fine-tune Epoch 9/50 - Avg Loss: 0.088047\n","Fine-tune Epoch 10/50 - Avg Loss: 0.092035\n","   >>> Val Accuracy sau epoch 10: 0.9074\n","Fine-tune Epoch 11/50 - Avg Loss: 0.089660\n","Fine-tune Epoch 12/50 - Avg Loss: 0.083642\n","Fine-tune Epoch 13/50 - Avg Loss: 0.084455\n","Fine-tune Epoch 14/50 - Avg Loss: 0.081987\n","Fine-tune Epoch 15/50 - Avg Loss: 0.086192\n","   >>> Val Accuracy sau epoch 15: 0.8981\n","Fine-tune Epoch 16/50 - Avg Loss: 0.090790\n","Fine-tune Epoch 17/50 - Avg Loss: 0.086767\n","Fine-tune Epoch 18/50 - Avg Loss: 0.083353\n","Fine-tune Epoch 19/50 - Avg Loss: 0.083601\n","Fine-tune Epoch 20/50 - 