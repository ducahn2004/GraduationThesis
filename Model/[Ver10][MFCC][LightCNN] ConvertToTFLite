t found. Installing {install_target} ...\")\n","\n","        # Install the package using pip\n","        subprocess.check_call([\n","            sys.executable,\n","            \"-m\",\n","            \"pip\",\n","            \"install\",\n","            install_target\n","        ])"]},{"cell_type":"code","source":["check_or_install(\"numpy\", version=\"1.26.4\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Z8t-piTZ3560","executionInfo":{"status":"ok","timestamp":1776083923552,"user_tz":-420,"elapsed":15,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"a8ebd0c8-688c-45de-c1d9-5e046b03b804"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["[OK] numpy is already installed (version: 1.26.4)\n"]}]},{"cell_type":"code","source":["#pip uninstall -y onnx onnxsim onnxruntime onnxscript onnx2tf onnx-graphsurgeon"],"metadata":{"id":"03Bd11a7s_M8","executionInfo":{"status":"ok","timestamp":1776083923555,"user_tz":-420,"elapsed":2,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}}},"execution_count":7,"outputs":[]},{"cell_type":"code","source":["check_or_install(\"onnx\", version=\"1.17.0\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"goiRLX_AfZMp","executionInfo":{"status":"ok","timestamp":1776083933560,"user_tz":-420,"elapsed":10002,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"a9a5810c-9a85-457f-ccc0-7598717f6389"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["[INSTALL] onnx not found. Installing onnx==1.17.0 ...\n"]}]},{"cell_type":"code","execution_count":9,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Tq2MVsyR_Pva","outputId":"cf5c33f7-790e-4653-e3c3-0f4eae1397e9","executionInfo":{"status":"ok","timestamp":1776083957841,"user_tz":-420,"elapsed":24278,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}}},"outputs":[{"output_type":"stream","name":"stdout","te