on = torch.nn.NLLLoss()  # vì model output log_softmax\n","\n","num_finetune_epochs = 50\n","#num_finetune_epochs = 2\n","for epoch in range(num_finetune_epochs):\n","    model.train()\n","    running_loss = 0.0\n","\n","    for inputs, labels in train_loader:\n","        inputs, labels = inputs.to(device), labels.to(device)\n","\n","        optimizer.zero_grad()\n","        outputs = model(inputs)\n","\n","        loss = criterion(outputs, labels)\n","\n","        loss.backward()\n","        optimizer.step()\n","        running_loss += loss.item()\n","\n","    scheduler.step()\n","    avg_loss = running_loss / len(train_loader)\n","    print(f\"Fine-tune Epoch {epoch+1}/{num_finetune_epochs} - Avg Loss: {avg_loss:.6f}\")\n","\n","    # Đánh giá trên validation (tùy chọn)\n","    if (epoch + 1) % 5 == 0 or epoch == num_finetune_epochs - 1:\n","        model.eval()\n","\n","        correct = total = 0\n","\n","        with torch.no_grad():\n","            for inputs, labels in val_loader:\n","                inputs, labels = inputs.to(device), labels.to(device)\n","                outputs = model(inputs)\n","                pred = torch.argmax(outputs, dim=1)\n","                correct += (pred == labels).sum().item()\n","                total += labels.size(0)\n","        acc = correct / total if total > 0 else 0\n","        print(f\"   >>> Val Accuracy sau epoch {epoch+1}: {acc:.4f}\")\n","        model.train()\n","\n","# Đóng dataset để giải phóng file handle\n","train_dataset.close()\n","val_dataset.close()\n","\n","model.eval()\n","print(\"Fine-tune sau pruning hoàn tất\")"]},{"cell_type":"code","execution_count":36,"metadata":{"id":"2BcQ8SgFbH4w","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776084303363,"user_tz":-420,"elapsed":2446,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"309f2b59-032c-4e46-b997-11c0e14fd975"},"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Đã remove pruning mask → pruning permanent\n","✅ Model pruned + finetuned lưu tại: /content/drive/MyDrive/AutomaticHeartSoundClassification-main/TFLITE/light_cnn_0406_135605_pruned_finetuned.pth\n"]}],"source":["# ================== LÀM PRUNING PERMANENT ==================\n","import torch.nn.utils.prune as prune  # nếu chưa import\n","\n","for module, name in parameters_to_prune:\n","    prune.remove(module, name)\n","\n","print(\"✅ Đã remove pruning mask → pruning permanent\")\n","\n","# ================== LƯU MODEL PRUNED ==================\n","PRUNED_PATH = PROJECT_PATH / \"TFLITE\" / f\"{MODEL_NAME.lower()}_{TIMESTAMP}_pruned_finetuned.pth\"\n","torch.save(model.state_dict(), PRUNED_PATH)\n","print(f\"✅ Model pruned + finetuned lưu tại: {PRUNED_PATH}\")"]},{"cell_type":"markdown","metadata":{"id":"x_h2-HDx3dYB"},"source":["## Define input shape & Dummy input"]},{"cell_type":"code","source":["# ─── Export ONNX (giữ nguyên để so sánh accuracy) ────────────────────────────\n","model.cpu().eval()\n","ONNX_PATH   = TFLITE_DIR / f\"{MODEL_NAME.lower()}_{TIMESTAMP}_final.onnx\"\n","dummy_input = torch.randn(1, N_MFCC, FIXED_LENGTH)\n","torch.onnx.export(model, dummy_input, str(ONNX_PATH),\n","                  export_params=True, opset_version=17,\n","                  input_names=[\"input\"], output_names=[\"output\"],\n","                  dynamic_axes={\"input\":{0:\"batch\"}, \"output\":{0:\"batch\"}})\n","print(f\"✅ ONNX: {ONNX_PATH}\")\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","#  CONVERT TO TFLITE — Keras rebuild + weight copy\n","#  (Thay thế onnx2tf VÀ tf.numpy_function wrapper)\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","\"\"\"## OPTION A / B — Chọn nguồn PyTorch weights\"\"\"\n","\n","# OPTION A: Dùng model đang trong memory (sau fine-tune ở trên)\n","print(\"Đang dùng model trong memory (Option A)\")\n","pt_state = model.state_dict()\n","\n","# OPTION B: Load lại từ file .pth — uncomment nếu chạy riêng\n","# PRUNED_PATH = TFLITE_DIR / f\"{MODEL_NAME.lower()}_{TIMESTAMP}_pruned_finetuned.pth\"\n","# tmp = LightweightHeartSoundCNN_V2(); tmp.load_state_dict(torch.load(PRUNED_PATH, map_location='cpu', weights_only=True))\n","# pt_state = tmp.state_dict()\n","# print(f\"✅ Load từ {PRUNED_PATH}\")\n","\n","import tensorflow as tf\n","import numpy as np\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","#  Bước 1: Tái tạo kiến trúc LightweightHeartSoundCNN_V2 bằng Keras thuần\n","#\n","#  Lý do: TFLite chỉ chấp nhận TF built-in ops. Bất kỳ Python callback nào\n","#  (tf.numpy_function, tf.py_function) đều sinh ra op `tf.PyFunc` → lỗi convert.\n","#  Giải pháp duy nhất không phụ thuộc onnx2tf: viết lại model bằng Keras.\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","def relu6(x):\n","    return tf.nn.relu6(x)\n","\n","def build_keras_model(num_classes=2, dropout=0.3):\n","    \"\"\"\n","    Tái tạo LightweightHeartSoundCNN_V2 bằng Keras functional API.\n","    Input shape: (batch, 1, 39, 333) — NCHW, giống PyTorch.\n","\n","    NOTE: TFLite ưa NHWC hơn. Ta dùng NHWC trong Keras (channels_last)\n","    và sẽ transpose weight khi copy từ PyTorch (NCHW → NHWC).\n","    Input data cần được transpose trước khi feed vào TFLite:\n","      PyTorch: (B, 1, 39, 333)  →  TFLite: (B, 39, 333, 1)\n","    \"\"\"\n","    inp = tf.keras.Input(shape=(N_MFCC, FIXED_LENGTH, 1), name=\"input\")  # (B,39,333,1) NHWC\n","\n","    # ── Stem: Conv3×3/s=2 ───────────────────────────────────────────────────\n","    x = tf.keras.layers.Conv2D(8, 3, strides=2, padding='same',\n","                                use_bias=False, name='stem_conv')(inp)\n","    x = tf.keras.layers.BatchNormalization(momentum=0.1, epsilon=1e-5,\n","                                            name='stem_bn')(x)\n","    x = tf.keras.layers.Lambda(relu6, name='stem_relu6')(x)\n","\n","    # ── Helper: DSConvBlock ──────────────────────────────────────────────────\n","    def ds_block(x, in_ch, out_ch, stride, prefix):\n","        # Depthwise conv\n","        x = tf.keras.layers.DepthwiseConv2D(3, strides=stride, padding='same',\n","                                             use_bias=False,\n","                                             name=f'{prefix}_dw')(x)\n","        # Pointwise conv\n","        x = tf.keras.layers.Conv2D(out_ch, 1, use_bias=False,\n","                                    name=f'{prefix}_pw')(x)\n","        x = tf.keras.layers.BatchNormalization(momentum=0.1, epsilon=1e-5,\n","                                                name=f'{prefix}_bn')(x)\n","        x = tf.keras.layers.Lambda(relu6, name=f'{prefix}_relu6')(x)\n","        return x\n","\n","    x = ds_block(x,  8,  16, stride=2, prefix='ds1')\n","    x = ds_block(x, 16,  32, stride=2, prefix='ds2')\n","    x = ds_block(x, 32,  48, stride=1, prefix='ds3')\n","    x = ds_block(x, 48,  64, stride=1, prefix='ds4')\n","\n","    # ── SE Block (LiteSEBlock, reduction=8, mid=8) ───────────────────────────\n","    se_gap = tf.keras.layers.GlobalAveragePooling2D(name='se_gap')(x)          # (B,64)\n","    se_fc1 = tf.keras.layers.Dense(8,  activation='relu',    name='se_fc1')(se_gap)\n","    se_fc2 = tf.keras.layers.Dense(64, activation='sigmoid', name='se_fc2')(se_fc1)\n","    se_w   = tf.keras.layers.Reshape((1, 1, 64), name='se_reshape')(se_fc2)\n","    x      = tf.keras.layers.Multiply(name='se_mul')([x, se_w])\n","\n","    # ── Head ─────────────────────────────────────────────────────────────────\n","    x = tf.keras.layers.GlobalAveragePooling2D(name='head_gap')(x)             # (B,64)\n","    x = tf.keras.layers.Dropout(dropout, name='head_drop')(x)\n","    out = tf.keras.layers.Dense(num_classes, name='head_fc')(x)                # (B,2)\n","\n","    return tf.keras.Model(inputs=inp, outputs=out, name='LightCNN_V2')\n","\n","keras_model = build_keras_model()\n","keras_model.summary()\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","#  Bước 2: Copy weights PyTorch → Keras\n","#\n","#  Quy ước PyTorch:   Conv weight shape (out_ch, in_ch, kH, kW)      = NCHW\n","#  Quy ước TF/Keras:  Conv weight shape (kH, kW, in_ch, out_ch)      = HWIO\n","#  Depthwise (PyTorch): (in_ch, 1, kH, kW)  →  TF: (kH, kW, in_ch, 1)\n","#  BatchNorm: gamma(weight), beta(bias), running_mean, running_var\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","sd = {k: v.numpy() for k, v in pt_state.items()}\n","\n","def pt_conv_to_tf(w):\n","    \"\"\"(out, in, kH, kW) → (kH, kW, in, out)\"\"\"\n","    return np.transpose(w, (2, 3, 1, 0))\n","\n","def pt_dw_to_tf(w):\n","    \"\"\"Depthwise: (in_ch, 1, kH, kW) → (kH, kW, in_ch, 1)\"\"\"\n","    return np.transpose(w, (2, 3, 0, 1))\n","\n","def copy_bn(keras_layer, pt_prefix):\n","    \"\"\"Copy BatchNorm: gamma, beta, mean, var\"\"\"\n","    gamma = sd[f'{pt_prefix}.weight']\n","    beta  = sd[f'{pt_prefix}.bias']\n","    mean  = sd[f'{pt_prefix}.running_mean']\n","    var   = sd[f'{pt_prefix}.running_var']\n","    keras_layer.set_weights([gamma, beta, mean, var])\n","\n","def copy_dsblock(prefix_pt, prefix_k):\n","    \"\"\"Copy một DSConvBlock (dw + pw + bn)\"\"\"\n","    # Depthwise\n","    dw_layer = keras_model.get_layer(f'{prefix_k}_dw')\n","    dw_layer.set_weights([pt_dw_to_tf(sd[f'{prefix_pt}.dw.weight'])])\n","    # Pointwise\n","    pw_layer = keras_model.get_layer(f'{prefix_k}_pw')\n","    pw_layer.set_weights([pt_conv_to_tf(sd[f'{prefix_pt}.pw.weight'])])\n","    # BatchNorm\n","    copy_bn(keras_model.get_layer(f'{prefix_k}_bn'), f'{prefix_pt}.bn')\n","\n","# Stem\n","keras_model.get_layer('stem_conv').set_weights([pt_conv_to_tf(sd['stem.0.weight'])])\n","copy_bn(keras_model.get_layer('stem_bn'), 'stem.1')\n","\n","# DS1–DS4\n","copy_dsblock('ds1', 'ds1')\n","copy_dsblock('ds2', 'ds2')\n","copy_dsblock('ds3', 'ds3')\n","copy_dsblock('ds4', 'ds4')\n","\n","# SE Block\n","# se.fc: Sequential(Linear(64,8), ReLU, Linear(8,64), Sigmoid)\n","# PyTorch Linear weight: (out, in) → Keras Dense weight: (in, out) → cần transpose\n","se_fc1_layer = keras_model.get_layer('se_fc1')\n","se_fc1_layer.set_weights([\n","    sd['se.fc.0.weight'].T,   # (64,8)\n","    sd['se.fc.0.bias'],\n","])\n","se_fc2_layer = keras_model.get_layer('se_fc2')\n","se_fc2_layer.set_weights([\n","    sd['se.fc.2.weight'].T,   # (8,64)\n","    sd['se.fc.2.bias'],\n","])\n","\n","# Head: Linear(64, 2)   → head.3 trong PyTorch Sequential\n","head_fc = keras_model.get_layer('head_fc')\n","head_fc.set_weights([\n","    sd['head.3.weight'].T,    # (64,2)\n","    sd['head.3.bias'],\n","])\n","\n","print(\"✅ Copy weights hoàn tất\")\n","\n","# ─── Kiểm tra nhanh: so sánh output PyTorch vs Keras ─────────────────────────\n","model.cpu().eval()\n","x_pt = torch.randn(1, N_MFCC, FIXED_LENGTH)\n","with torch.no_grad():\n","    out_pt = model(x_pt).numpy()                          # (1,2)\n","\n","# Keras nhận (B, H, W, C) = (1, 39, 333, 1)\n","x_tf = x_pt.numpy().transpose(0, 2, 3, 1) if x_pt.dim() == 4 else \\\n","       x_pt.numpy()[np.newaxis].transpose(0, 2, 3, 1)    # fallback\n","# Thực ra input (1,39,333) → thêm channel dim → (1,39,333,1)\n","x_np = x_pt.numpy()                                       # (1,39,333)\n","x_tf = x_np[..., np.newaxis].transpose(0, 2, 3, 1)        # Sai! Làm đúng:\n","x_tf = x_np[:, np.newaxis, :, :]                           # (1,1,39,333) NCHW\n","x_tf = x_tf.transpose(0, 2, 3, 1)                         # (1,39,333,1) NHWC\n","\n","out_keras = keras_model.predict(x_tf, verbose=0)          # (1,2)\n","\n","print(f\"PyTorch output : {out_pt}\")\n","print(f\"Keras   output : {out_keras}\")\n","max_diff = np.abs(out_pt - out_keras).max()\n","print(f\"Max diff       : {max_diff:.6f}  ({'✅ OK' if max_diff < 0.01 else '⚠️ Lớn, kiểm tra lại copy_weights'})\")\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","#  Bước 3: Lưu SavedModel (chỉ chứa TF built-in ops)\n","# ══════════════════════════════════════════════════════════════════════════════\n","SAVED_MODEL_DIR = str(TFLITE_DIR / f\"{MODEL_NAME.lower()}_{TIMESTAMP}_saved_model_v2\")\n","keras_model.save(SAVED_MODEL_DIR)\n","print(f\"✅ SavedModel lưu tại: {SAVED_MODEL_DIR}\")\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","#  Bước 4: TFLiteConverter — Integer with Float Fallback\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","\"\"\"## Chuẩn bị Representative Dataset\"\"\"\n","\n","def make_calib_npy(h5_path, save_path=\"calib_nhwc.npy\", n=300, seed=42):\n","    \"\"\"\n","    Calibration data shape (N, 39, 333, 1) — NHWC float32.\n","    Khớp với Keras model input shape (batch, H, W, C).\n","    \"\"\"\n","    rng = np.random.default_rng(seed)\n","    out = []\n","    with h5py.File(h5_path, 'r') as hf:\n","        keys = list(hf.keys()); rng.shuffle(keys); keys = keys[:n]\n","        for k in keys:\n","            d = hf[k][()].astype(np.float32)           # (39, T)\n","            d = (d - d.mean()) / (d.std() + EPS)\n","            T = d.shape[1]\n","            if T >= FIXED_LENGTH:\n","                s = (T - FIXED_LENGTH) // 2; d = d[:, s:s+FIXED_LENGTH]\n","            else:\n","                d = np.pad(d, ((0,0),(0, FIXED_LENGTH-T)), mode='constant')\n","            # (39,333) → (39,333,1) NHWC\n","            out.append(d[:, :, np.newaxis])\n","    calib = np.stack(out, axis=0).astype(np.float32)   # (N,39,333,1)\n","    np.save(save_path, calib)\n","    print(f\"✅ Calib shape={calib.shape}  std={calib.std():.4f}  saved→{save_path}\")\n","    return calib\n","\n","CALIB_H5   = DATASET_PATH / \"mfcc_39_train.h5\"\n","calib_data = make_calib_npy(CALIB_H5, save_path=\"calib_nhwc.npy\", n=300)\n","\n","def representative_dataset():\n","    \"\"\"Generator cho TFLiteConverter — mỗi yield là list[(1,39,333,1)].\"\"\"\n","    for i in range(len(calib_data)):\n","        yield [calib_data[i:i+1]]   # (1,39,333,1) float32\n","\n","\"\"\"## Convert\"\"\"\n","\n","converter = tf.lite.TFLiteConverter.from_saved_model(SAVED_MODEL_DIR)\n","\n","# ── INT8 quantization ─────────────────────────────────────────────────────────\n","converter.optimizations           = [tf.lite.Optimize.DEFAULT]\n","converter.representative_dataset  = representative_dataset\n","\n","# Integer with float fallback:\n","#   - Ưu tiên dùng INT8 kernel cho mọi op.\n","#   - Nếu op không có INT8 impl → dùng float32 (không crash như full-integer).\n","#   - I/O giữ float32 → không cần quantize/dequantize thủ công khi inference.\n","converter.target_spec.supported_ops = [\n","    tf.lite.OpsSet.TFLITE_BUILTINS_INT8,  # INT8 kernel\n","    tf.lite.OpsSet.TFLITE_BUILTINS,       # float fallback\n","]\n","converter.inference_input_type  = tf.float32  # I/O float32 → tương thích ONNX test\n","converter.inference_output_type = tf.float32\n","\n","print(\"⏳ Converting to TFLite INT8...\")\n","tflite_model = converter.convert()\n","print(\"✅ Convert thành công!\")\n","\n","# ── Lưu file ─────────────────────────────────────────────────────────────────\n","OUTPUT_TFLITE_DIR = TFLITE_DIR / f\"{MODEL_NAME.lower()}_tflite_int8_{TIMESTAMP}\"\n","OUTPUT_TFLITE_DIR.mkdir(parents=True, exist_ok=True)\n","int8_tflite_path  = OUTPUT_TFLITE_DIR / f\"{MODEL_NAME.lower()}_{TIMESTAMP}_int8_float_io.tflite\"\n","\n","with open(int8_tflite_path, \"wb\") as f:\n","    f.write(tflite_model)\n","\n","size_kb = int8_tflite_path.stat().st_size / 1024\n","print(f\"✅ TFLite saved: {int8_tflite_path}  ({size_kb:.1f} KB)\")\n","\n","# ── Kiểm tra I/O ─────────────────────────────────────────────────────────────\n","interp = tf.lite.Interpreter(model_path=str(int8_tflite_path), experimental_delegates=[])\n","interp.allocate_tensors()\n","inp_d = interp.get_input_details()[0]\n","out_d = interp.get_output_details()[0]\n","print(f\"Input  dtype={inp_d['dtype'].__name__}  shape={inp_d['shape']}\")\n","print(f\"       scale={inp_d['quantization'][0]:.6f}  zp={inp_d['quantization'][1]}\")\n","print(f\"Output dtype={out_d['dtype'].__name__}  scale={out_d['quantization'][0]:.6f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"or8zh7fe51MQ","executionInfo":{"status":"error","timestamp":1776084838840,"user_tz":-420,"elapsed":13455,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"5b2e0f4a-d141-4386-e585-bb6a25a441a4"},"execution_count":54,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_11600/881795839.py:5: UserWarning: # 'dynamic_axes' is not recommended when dynamo=True, and may lead to 'torch._dynamo.exc.UserError: Constraints violated.' Supply the 'dynamic_shapes' argument instead if export is unsuccessful.\n","  torch.onnx.export(model, dummy_input, str(ONNX_PATH),\n","W0413 12:53:48.291000 11600 torch/onnx/_internal/exporter/_compat.py:125] Setting ONNX exporter to use operator set version 18 because the requested opset_version 17 is a lower version than we have implementations for. Automatic version conversion will be performed, which may not be successful at converting to the requested version. If version conversion is unsuccessful, the opset version of the exported model will be kept at 18. Please consider setting opset_version >=18 to leverage latest ONNX features\n"]},{"output_type":"stream","name":"stdout","text":["[torch.onnx] Obtain model graph for `LightweightHeartSoundCNN_V2([...]` with `torch.export.export(..., strict=False)`...\n","[torch.onnx] Obtain model graph for `LightweightHeartSoundCNN_V2([...]` with `torch.export.export(..., strict=False)`... ✅\n","[torch.onnx] Run decomposition...\n"]},{"output_type":"stream","name":"stderr","text":["/usr/lib/python3.12/copyreg.py:99: FutureWarning: `isinstance(treespec, LeafSpec)` is deprecated, use `isinstance(treespec, Tr