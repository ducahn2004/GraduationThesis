size=(1, 2))\\n\\n    # -------- Block 2 --------\\n    x = F.relu(model.bn2(model.conv2(x)))\\n    x = model.drop2(x)\\n    x = F.max_pool2d(x, kernel_size=(1, 2))\\n\\n    # -------- Block 3 --------\\n    x = F.relu(model.bn3(model.conv3(x)))\\n    x = model.drop3(x)\\n\\n    # -------- Global Average Pooling --------\\n    x = model.gap(x)          # (B, 64, 1, 1)\\n    x = x.view(B, -1)         # (B, 64)\\n\\n    # -------- Classifier --------\\n    output = model.classifier(x)  # KHÔNG softmax (đúng cho edge / ONNX)\\n\\n    return output\\n\\n\\ndef export_forward_vgg(input):\\n    B, mel_bins, num_frames = input.size()\\n    x = input.view(B, model.in_channel, -1, num_frames)\\n    x = x.transpose(1, 2)\\n    x = model.bn0(x)\\n    x = x.transpose(1, 2)\\n\\n    x = model.conv1(x, pool_size=(2, 2), pool_type=\\'max\\')\\n\\n    x = nn.AdaptiveMaxPool2d((1, 1))(x)\\n    x = x.view(B, -1)\\n    output = model.fc_final(x)\\n    return output\\n\\ndef export_forward_crnn(input):\\n    \"\"\"\\n    ONNX-compatible forward pass\\n    Uses fixed kernel size for pooling instead of adaptive pooling\\n    \"\"\"\\n    B, mel_bins, num_frames = input.size()\\n\\n    # Reshape\\n    x = input.view(B, model.in_channel, mel_bins // model.in_channel, num_frames)\\n\\n    # CNN encoder - this includes 4 ConvBlocks with pooling\\n    x = model.cnn(x)\\n\\n    # Pool frequency dimension using FIXED kernel size\\n    # This replaces F.adaptive_max_pool2d(x, (1, None))\\n    x = torch.nn.functional.max_pool2d(\\n        x,\\n        kernel_size=(freq_dim_after_cnn, 1)  # Use calculated size\\n    )\\n    x = x.squeeze(2)  # Remove frequency dimension\\n\\n    # BiLSTM\\n    output = model.bilstm(x)\\n\\n    return output\\n\\noriginal_forward = model.forward\\n\\ndef export_forward_lightcnn(input):\\n    \"\"\"\\n    ONNX-compatible forward for LightweightHeartSoundCNN (Ver 8)\\n    \"\"\"\\n    B, CMel, T = input.size()\\n    x = input.view(B, model.in_channel, CMel // model.in_channel, T)\\n\\n    x = model.stem(x)\\n    x = model.stage1(x)\\n    x = model.stage2(x)\\n    x = model.stage3(x)\\n    x = model.se(x)\\n    x = model.gap(x).flatten(1)   # ✅ Phải có x =\\n    x = model.bn_head(x)\\n    x = model.dropout_layer(x)\\n    output = model.classifier(x)\\n    return output\\n\\nif MODEL_NAME == \"CNN\":\\n    model.forward = export_forward_simple_cnn\\nelif MODEL_NAME == \"VGG11\":\\n    model.forward = export_forward_vgg\\nelif MODEL_NAME == \"CRNN\":\\n    model.forward = export_forward_crnn\\nelif MODEL_NAME == \"Light_CNN\":\\n    model.forward = export_forward_lightcnn\\nelse:\\n    raise ValueError(\"Unsupported model\")\\n    '"],"application/vnd.google.colaboratory.intrinsic+json":{"type":"string"}},"metadata":{},"execution_count":41}],"source":["'''\n","original_forward = model.forward\n","def export_forward_simple_cnn(input):\n","    \"\"\"\n","    ONNX-compatible forward for simple_cnn\n","    Consistent with training architecture\n","    \"\"\"\n","    B, mel_bins, num_frames = input.size()\n","\n","    # (B, mel, time) → (B, C, mel, time)\n","    x = input.view(B, model.in_channel, mel_bins, num_frames)\n","\n","    # -------- Block 1 --------\n","    x = F.relu(model.bn1(model.conv1(x)))\n","    x = model.drop1(x)\n","    x = F.max_pool2d(x, kernel_size=(1, 2))\n","\n","    # -------- Block 2 --------\n","    x = F.relu(model.bn2(model.conv2(x)))\n","    x = model.drop2(x)\n","    x = F.max_pool2d(x, kernel_size=(1, 2))\n","\n","    # -------- Block 3 --------\n","    x = F.relu(model.bn3(model.conv3(x)))\n","    x = model.drop3(x)\n","\n","    # -------- Global Average Pooling --------\n","    x = model.gap(x)          # (B, 64, 1, 1)\n","    x = x.view(B, -1)         # (B, 64)\n","\n","    # -------- Classifier --------\n","    output = model.classifier(x)  # KHÔNG softmax (đúng cho edge / ONNX)\n","\n","    return output\n","\n","\n","def export_forward_vgg(input):\n","    B, mel_bins, num_frames = input.size()\n","