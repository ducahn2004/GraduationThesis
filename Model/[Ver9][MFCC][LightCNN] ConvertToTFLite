on']\n","\n","    print(f\"Input  dtype={in_dtype.__name__}  shape={input_details['shape']}\")\n","    print(f\"       scale={in_scale:.6f}  zp={in_zp}\")\n","    print(f\"Output dtype={out_dtype.__name__}  scale={out_scale:.6f}  zp={out_zp}\")\n","\n","    correct = total = TP = TN = FP = FN = 0\n","\n","    for features, labels in data_loader:\n","        for i in range(features.shape[0]):\n","            # DataLoader trả (B, 39, 333) → transpose → (1, 333, 39)\n","            x = np.expand_dims(features[i].numpy().T, 0).astype(np.float32)\n","\n","            # Quantize input nếu cần\n","            if in_dtype == np.int8:\n","                x = np.clip(np.round(x / in_scale) + in_zp, -128, 127).astype(np.int8)\n","            elif in_dtype == np.uint8:\n","                x = np.clip(np.round(x / in_scale) + in_zp, 0, 255).astype(np.uint8)\n","            # float32: dùng thẳng, không cần làm gì\n","\n","            interpreter.set_tensor(input_details['index'], x)\n","            interpreter.invoke()\n","            output = interpreter.get_tensor(output_details['index'])  # shape (1, 2)\n","\n","            # Dequantize output nếu cần\n","            if out_dtype == np.int8:\n","                output = (output.astype(np.float32) - out_zp) * out_scale\n","            elif out_dtype == np.uint8:\n","                output = (output.astype(np.float32) - out_zp) * out_scale\n","            # float32: dùng thẳng\n","\n","            pred = int(np.argmax(output[0]))\n","            gt   = int(labels[i].item())\n","\n","            if pred == gt: correct += 1\n","            if   gt == 1 and pred == 1: TP += 1\n","            elif gt == 1 and pred == 0: FN += 1\n","            elif gt == 0 and pred == 0: TN += 1\n","            else:                       FP += 1\n","            total += 1\n","\n","    acc = correct / total\n","    sen = TP / (TP + FN) if (TP + FN) > 0 else 0\n","    spe = TN / (TN + FP) if (TN + FP) > 0 else 0\n","    print(f\"\\n  Accuracy    : {a