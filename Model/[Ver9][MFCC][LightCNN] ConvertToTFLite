lass(\n","        in_channel=cfg[\"in_channel\"],\n","        num_classes=cfg[\"num_classes\"]\n","    )\n","\n","else:\n","    raise ValueError(\"Cấu hình model không hợp lệ\")\n","\n","\n","checkpoint = torch.load(model_path, map_location=device, weights_only=False)\n","state_dict = checkpoint.get('state_dict', checkpoint)\n","model.load_state_dict(state_dict)\n","model.to(device)\n","model.eval()"]},{"cell_type":"markdown","metadata":{"id":"MA2a4z-V5eou"},"source":["# Punning"]},{"cell_type":"code","execution_count":30,"metadata":{"id":"kTLzc77p5IVi","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776039839878,"user_tz":-420,"elapsed":285,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"f56d62f0-c294-4909-cb79-7f53ac3c5930"},"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Đã apply pruning (với mask)\n"]}],"source":["import torch.nn.utils.prune as prune\n","\n","parameters_to_prune = []\n","for name, module in model.named_modules():\n","    if isinstance(module, (torch.nn.Conv2d, torch.nn.Linear)):\n","        parameters_to_prune.append((module, 'weight'))\n","        # Optional: prune bias too\n","        # if module.bias is not None:\n","        #     parameters_to_prune.append((module, 'bias'))\n","\n","prune.global_unstructured(\n","    parameters_to_prune,\n","    pruning_method=prune.L1Unstructured,\n","    amount=0.2,\n",")\n","\n","print(\"✅ Đã apply pruning (với mask)\")"]},{"cell_type":"code","execution_count":31,"metadata":{"id":"-i4lG_4VAxJn","executionInfo":{"status":"ok","timestamp":1776039839950,"user_tz":-420,"elapsed":69,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}}},"outputs":[],"source":["import librosa\n","import random\n","import numpy as np\n","import torch\n","import torch.nn.functional as F\n","from torch.utils.data import Dataset, DataLoader\n","\n","EPS = 1e-8\n","\n","def standard_normal_variate(data):\n","    \"\"\"Z-score normalization trên toàn bộ feature\"\"\"\n","    mean = np.mean(data)\n","    std = np.std(data) + EPS\n","    return (data - mean) / std\n","\n","class MFCCDataset(Dataset):\n","    def __init__(self, features_h5_path, label_csv_path, keys=None,\n","                 norm=True, duration=5, hop_length=15, training=False):\n","        self.features_h5_path = features_h5_path\n","        self.labels_df = pd.read_csv(label_csv_path)\n","\n","        # Tạo mapping để tra cứu nhãn nhanh\n","        self.key_to_label = dict(\n","            zip(self.labels_df.iloc[:, 0].apply(lambda x: Path(x).stem if '/' in str(x) else str(x)),\n","                self.labels_df.iloc[:, 1])\n","        )\n","\n","        with h5py.File(features_h5_path, 'r') as hf:\n","            available_keys = set(hf.keys())\n","            if keys is None:\n","                # Nếu không truyền keys, mặc định lấy hết\n","                self.keys = [k for k in available_keys if k in self.key_to_label]\n","            else:\n","                # Chỉ lấy những keys vừa tồn tại trong file H5 vừa có nhãn\n","                self.keys = [k for k in keys if k in available_keys and k in self.key_to_label]\n","\n","        self.norm = norm\n","        self.training = training\n","        self.fixed_length = int(duration * 1000 / hop_length)\n","        self._hf = None\n","\n","    def _get_hf(self):\n","        if self._hf is None:\n","            self._hf = h5py.File(self.features_h5_path, 'r')\n","        return self._hf\n","\n","    def __len__(self):\n","        return len(self.keys)\n","\n","    def __getitem__(self, idx):\n","        key = self.keys[idx]\n","        mfcc = self._get_hf()[key][()].astype(np.float32)\n","\n","        if self.norm:\n","            mfcc = standard_normal_variate(mfcc)\n","\n","        n_mfcc, T = mfcc.shape\n","        if T >= self.fixed_length:\n","            start = (T - self.fixed_length) // 2\n","            mfcc = mfcc[:, start:start + self.fixed_length]\n","        else:\n","            mfcc = np.pad(mfcc, ((0, 0), (0, self.fixed_length - T)), mode=\"constant\")\n","\n","        return (\n","            torch.from_numpy(mfcc),\n","            torch.tensor(self.key_to_label.get(key, 0), dtype=torch.long)\n","        )\n","\n","    def close(self):\n","        if self._hf is not None:\n","            self._hf.close()\n","            self._hf = None"]},{"cell_type":"code","source":["import h5py\n","print(h5py.__version__)"],"metadata":{"id":"WjJ2ONv9SQG3","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776039839976,"user_tz":-420,"elapsed":21,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"283f9882-3945-46ad-9624-20cf10b2d7c7"},"execution_count":32,"outputs":[{"output_type":"stream","name":"stdout","text":["3.11.0\n"]}]},{"cell_type":"code","execution_count":33,"metadata":{"id":"y_LClACDJrZE","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776039865616,"user_tz":-420,"elapsed":25638,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"f98f7687-3ca2-4a87-a05a-81f36e3b9d95"},"outputs":[{"output_type":"stream","name":"stdout","text":["Train: 3656 samples | Val: 648 samples\n","Balanced: 1596 sample/case.  Total: 3656\n"]}],"source":["TRAIN_H5  = DATASET_PATH / \"mfcc_39_train.h5\"\n","TRAIN_CSV = DATASET_PATH / \"label_39_train_augmented.csv\"\n","VAL_H5    = DATASET_PATH / \"mfcc_39_val_internal.h5\"\n","VAL_CSV   = DATASET_PATH / \"label_39_val_clean.csv\"\n","\n","\n","# Đọc file label để phân loại keys\n","labels_df = pd.read_csv(TRAIN_CSV)\n","# Chuẩn hóa tên file (stem) để khớp với key trong H5\n","labels_df['stem'] = labels_df.iloc[:, 0].apply(lambda x: Path(x).stem)\n","\n","# Tách keys theo nhãn\n","keys_normal = labels_df[labels_df.iloc[:, 1] == 0]['stem'].values\n","keys_abnormal = labels_df[labels_df.iloc[:, 1] == 1]['stem'].values\n","\n","# Lấy số lượng mẫu bằng với số lượng của lớp ít hơn (thường là Abnormal)\n","num_samples_per_class = min(len(keys_normal), len(keys_abnormal))\n","\n","\n","balanced_normal = np.random.choice(keys_normal, num_samples_per_class, replace=False)\n","balanced_abnormal = np.random.choice(keys_abnormal, num_samples_per_class, replace=False)\n","\n","# Lấy mẫu ngẫu nhiên hoặc lấy đầu danh sách để cân bằng\n","balanced_keys = np.concatenate([balanced_normal, balanced_abnormal])\n","np.random.shuffle(balanced_keys) # Trộn đều nhãn\n","\n","train_dataset = MFCCDataset(TRAIN_H5, TRAIN_CSV, training=True)   # keys=None → tự lấy từ TRAIN_H5\n","val_dataset   = MFCCDataset(VAL_H5,   VAL_CSV,   training=False)  # keys=None → tự lấy từ VAL_H5\n","\n","print(f\"Train: {len(train_dataset)} samples | Val: {len(val_dataset)} samples\")\n","print(f\"Balanced: {num_samples_per_class} sample/case.  Total: {len(train_dataset)}\")\n","\n","train_loader = DataLoader(train_dataset, batch_size=64, shuffle=True,\n","                          num_workers=2, pin_memory=True)\n","val_loader   = DataLoader(val_dataset,   batch_size=64, shuffle=False,\n","                          num_workers=2, pin_memory=True)"]},{"cell_type":"code","source":["criterion = AsymmetricFocalLoss(\n","    gamma_pos=0.5,    # Giữ sensitivity cao cho lớp Abnormal\n","    gamma_neg=2.0,    # Phạt nặng False Positive (nhãn Normal bị đoán sai)\n","    label_smoothing=0.05\n",")"],"metadata":{"id":"XgC23eDybMd8","executionInfo":{"status":"ok","timestamp":1776039865617,"user_tz":-420,"elapsed":13,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}}},"execution_count":34,"outputs":[]},{"cell_type":"code","execution_count":35,"metadata":{"id":"ZKkKmnOR5Pwt","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776040087813,"user_tz":-420,"elapsed":222202,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"9955cd32-d14f-469b-9899-ed682c82ed46"},"outputs":[{"output_type":"stream","name":"stdout","text":["