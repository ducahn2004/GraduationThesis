 tflite_files[0]  # nếu không có thì dùng file đầu tiên\n",")\n","\n","print(f\"Đang test với: {int8_file.name} ({format_size(int8_file.stat().st_size)})\\n\")\n","\n","# Load và test model\n","interpreter = tf.lite.Interpreter(model_path=str(int8_file))\n","interpreter.allocate_tensors()\n","\n","input_details = interpreter.get_input_details()\n","output_details = interpreter.get_output_details()\n","\n","print(\"=== THÔNG TIN INPUT ===\")\n","for i, detail in enumerate(input_details):\n","    print(f\"Input {i}:\")\n","    print(f\"  Name: {detail['name']}\")\n","    print(f\"  Shape: {detail['shape']}\")\n","    print(f\"  Dtype: {detail['dtype']}\")\n","    print(f\"  Quantization: {detail['quantization']}\")\n","\n","print(\"\\n=== THÔNG TIN OUTPUT ===\")\n","for detail in output_details:\n","    print(f\"Output shape: {detail['shape']}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"UKIlMv8Vetjy"},"outputs":[],"source":["import h5py\n","import pandas as pd\n","import numpy as np\n","import torch\n","from torch.utils.data import Dataset, DataLoader\n","import librosa\n","from pathlib import Path\n","\n","PROJECT_PATH = Path('/content/drive/MyDrive/AutomaticHeartSoundClassification-main')\n","DATASET_PATH = PROJECT_PATH / \"data\"\n","\n","features_file = DATASET_PATH / \"mfcc_features.h5\"\n","label_file = DATASET_PATH / \"label_balanced.csv\"\n","\n","# ================== LOGMEL DATASET ==================\n","EPS = 1e-8\n","\n","def standard_normal_variate(data):\n","    mean = np.mean(data)\n","    std = np.std(data) + EPS\n","    return (data - mean) / std\n","\n","class MFCCDataset(Dataset):\n","    def __init__(\n","        self,\n","        features_h5_path,\n","        label_csv_path,\n","        keys=None,\n","        norm=True,\n","        duration=5,\n","        hop_length=15,\n","        training=False\n","    ):\n","        self.features_h5 = h5py.File(features_h5_path, 'r')\n","        self.labels_df = pd.read_csv(label_csv_path)\n","\n","        self.keys = list(self.features_h5.keys()) if keys is None else keys\n","        self.key_to_label = dict(\n","            zip(\n","                self.labels_df.iloc[:, 0].astype(str),\n","                self.labels_df.iloc[:, 1]\n","            )\n","        )\n","\n","        self.norm = norm\n","        self.training = training\n","        self.fixed_length = int(duration * 1000 / hop_length)  # 333\n","\n","    def __len__(self):\n","        return len(self.keys)\n","\n","    def __getitem__(self, idx):\n","        key = self.keys[idx]\n","\n","        # MFCC gốc: (13, T)\n","        mfcc = self.features_h5[key][()].astype(np.float32)\n","\n","        if self.norm:\n","            mfcc = standard_normal_variate(mfcc)\n","\n","        n_mfcc, T = mfcc.shape\n","\n","        # crop / pad time axis\n","        if T >= self.fixed_length:\n","            start = (T - self.fixed_length) // 2\n","            mfcc = mfcc[:, start:start + self.fixed_length]\n","        else:\n","            pad = self.fixed_length - T\n","            mfcc = np.pad(mfcc, ((0, 0), (0, pad)), mode=\"constant\")\n","\n","        # FINAL SHAPE: (13, 333)\n","        feature_tensor = torch.from_numpy(mfcc)\n","        label = torch.tensor(self.key_to_label.get(key, 0), dtype=torch.long)\n","\n","        return feature_tensor, label\n","\n","    def close(self):\n","        self.features_h5.close()\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"fgWDsV3devhM","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1770136625769,"user_tz":-420,"elapsed":48,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"3287fc95-8de5-4511-a0d4-84427dc6c500"},"outputs":[{"output_type":"stream","name":"stdout","text":["Tổng số mẫu: 5235\n","✅ Đã tạo DataLoader MFCC thành công!\n"]}],"source":["import h5py\n","from torch.utils.data import DataLoader\n","\n","# ============================================================\n","# LOAD ALL KEYS FROM MFCC HDF5\n","# ============================================================\n","with h5py.File(features_file, 'r') as hf:\n","    all_keys = list(hf.keys())\n","\n","print(f\"Tổng số mẫu: {len(all_keys)}\")\n","\n","# ============================================================\n","# CREATE FULL DATASET FOR FINAL EVALUATION (MFCC)\n","# ============================================================\n","full_dataset = MFCCDataset(\n","    features_h5_path=features_file,\n","    label_csv_path=label_file,\n","    keys=all_keys,\n","    #use_delta=True,     # MFCC + Δ + Δ² → 39 coefficients\n","    norm=True,\n","    duration=5,\n","    hop_length=15,\n","    training=False      # không random crop (center crop)\n",")\n","\n","# ============================================================\n","# DATALOADER\n","# ============================================================\n","full_loader = DataLoader(\n","    full_dataset,\n","    batch_size=32,\n","    shuffle=False,\n","    num_workers=2,\n","    pin_memory=True\n",")\n","\n","print(\"✅ Đã tạo DataLoader MFCC thành công!\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"DewFVNZVex07"},"outputs":[],"source":["def test_tflite_accuracy(tflite_path, data_loader):\n","    interpreter = tf.lite.Interpreter(model_path=str(tflite_path))\n","    interpreter.allocate_tensors()\n","\n","    input_details = interpreter.get_input_details()\n","    output_details = interpreter.get_output_details()\n","\n","    _, T, F = input_details[0]['shape']  # (1, time, freq)\n","\n","    print(f\"Testing model: {tflite_path.name}\")\n","    print(f\"Expected input shape: (1, {T}, {F})\")\n","\n","    correct, total = 0, 0\n","\n","    for features, labels in data_loader:\n","        for i in range(features.shape[0]):\n","            x = features[i].numpy()  # (freq, time) hoặc (time, freq)\n","\n","            # Chuẩn hóa về (time, freq)\n","            if x.shape == (F, T):\n","                x = x.T\n","            elif x.shape != (T, F):\n","                raise ValueError(\n","                    f\"Feature shape mismatch: got {x.shape}, expected {(T, F)}\"\n","                )\n","\n","            x = np.expand_dims(x, axis=0).astype(np.float32)\n","\n","            interpreter.set_tensor(input_details[0]['index'], x)\n","            interpreter.invoke()\n","            output = interpreter.get_tensor(output_details[0]['index'])\n","\n","            pred = np.argmax(output, axis=1)[0]\n","            if pred == labels[i].item():\n","                correct += 1\n","            total += 1\n","\n","    acc = correct / total\n","    print(f\"=> Accuracy: {acc*100:.2f}% ({correct}/{total})\")\n","    return acc"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"9smgNBV3ezLq","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1770136633282,"user_tz":-420,"elapsed":3363,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"b8e1548f-40f5-4b4d-a82e-c54f7fced5b5"},"outputs":[{"output_type":"stream","name":"stdout","text":["Đang test với: light_cnn_0203_153447_no_init_state_integer_quant.tflite\n","Testing model: light_cnn_0203_153447_no_init_state_integer_quant.tflite\n","Expected input shape: (1, 333, 13)\n","=> Accuracy: 49.19% (2575/5235)\n"]}],"source":["from pathlib import Path\n","\n","# Tìm file INT8\n","tflite_files = list(OUTPUT_TFLITE_DIR.glob(\"*integer*.tflite\")) + list(OUTPUT_TFLITE_DIR.glob(\"*quant*.tflite\"))\n","if not tflite_files:\n","    raise FileNotFoundError(\"Không tìm thấy file TFLite INT8!\")\n","\n","int8_tflite_path = tflite_files[0]\n","print(f\"Đang test với: {int8_tflite_path.name}\")\n","\n","# Chạy test\n","test_tflite_accuracy(int8_tflite_path, full_loader)\n","\n","# Đóng dataset\n","full_dataset.close()"]},{"cell_type":"markdown","source":["## Validation"],"metadata":{"id":"my2fbISBfb7O"}},{"cell_type":"code","source":["PROJECT_PATH = Path('/con