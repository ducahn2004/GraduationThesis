)\n","    (3): Dropout2d(p=0.15, inplace=False)\n","    (4): DepthwiseSeparableConv(\n","      (depthwise): Conv2d(64, 64, kernel_size=(3, 3), stride=(2, 2), padding=(1, 1), groups=64, bias=False)\n","      (pointwise): Conv2d(64, 128, kernel_size=(1, 1), stride=(1, 1), bias=False)\n","      (bn): BatchNorm2d(128, eps=1e-05, momentum=0.1, affine=True, track_running_stats=True)\n","      (relu): ReLU6(inplace=True)\n","    )\n","    (5): Dropout2d(p=0.15, inplace=False)\n","  )\n","  (pool): AdaptiveAvgPool2d(output_size=1)\n","  (classifier): Sequential(\n","    (0): Dropout(p=0.3, inplace=False)\n","    (1): Linear(in_features=128, out_features=2, bias=True)\n","  )\n",")"]},"metadata":{},"execution_count":72}]},{"cell_type":"code","execution_count":null,"metadata":{"id":"pNaWD8uh3cZT"},"outputs":[],"source":["# ================== DEFINE INPUT SHAPE & DUMMY INPUT ==================\n","# Input shape cố định sau khi fix dataset: (batch, 384, 333)\n","# MFCC: 39 coefficients\n","N_MFCC = 39\n","T = 333   # hoặc chiều thời gian bạn đang dùng\n","\n","dummy_input = torch.randn(1, N_MFCC, T)"]},{"cell_type":"markdown","metadata":{"id":"Ghh46LBo3uGo"},"source":["# Chuyển sang ONXX"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"lBQl35W33wfU","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1770135870510,"user_tz":-420,"elapsed":16,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"4d532c09-d8ff-4732-d8de-e27919879dbc"},"outputs":[{"output_type":"stream","name":"stdout","text":["/content/drive/MyDrive/AutomaticHeartSoundClassification-main/TFLITE/light_cnn_0203_153447_final.onnx\n"]}],"source":["# Export\n","ONNX_PATH = PROJECT_PATH / \"TFLITE\" / f\"{MODEL_NAME.lower()}_{TIMESTAMP}_final.onnx\"\n","ONNX_PATH.parent.mkdir(parents=True, exist_ok=True)\n","print(ONNX_PATH)"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"YJDxNj3GOO5e"},"outputs":[],"source":["original_forward = model.forward\n","\n","def export_forward_simple_cnn(input):\n","    \"\"\"\n","    ONNX-compatible forward for simple_cnn\n","    Consistent with training architecture\n","    \"\"\"\n","    B, mel_bins, num_frames = input.size()\n","\n","    # (B, mel, time) → (B, C, mel, time)\n","    x = input.view(B, model.in_channel, mel_bins, num_frames)\n","\n","    # -------- Block 1 --------\n","    x = F.relu(model.bn1(model.conv1(x)))\n","    x = model.drop1(x)\n","    x = F.max_pool2d(x, kernel_size=(1, 2))\n","\n","    # -------- Block 2 --------\n","    x = F.relu(model.bn2(model.conv2(x)))\n","    x = model.drop2(x)\n","    x = F.max_pool2d(x, kernel_size=(1, 2))\n","\n","    # -------- Block 3 --------\n","    x = F.relu(model.bn3(model.conv3(x)))\n","    x = model.drop3(x)\n","\n","    # -------- Global Average Pooling --------\n","    x = model.gap(x)          # (B, 64, 1, 1)\n","    x = x.view(B, -1)         # (B, 64)\n","\n","    # -------- Classifier --------\n","    output = model.classifier(x)  # KHÔNG softmax (đúng cho edge / ONNX)\n","\n","    return output\n","\n","\n","def export_forward_vgg(input):\n","    B, mel_bins, num_frames = input.size()\n","    x = input.view(B, model.in_channel, -1, num_frames)\n","    x = x.transpose(1, 2)\n","    x = model.bn0(x)\n","    x = x.transpose(1, 2)\n","\n","    x = model.conv1(x, pool_size=(2, 2), pool_type='max')\n","\n","    x = nn.AdaptiveMaxPool2d((1, 1))(x)\n","    x = x.view(B, -1)\n","    output = model.fc_final(x)\n","    return output\n","\n","def export_forward_crnn(input):\n","    \"\"\"\n","    ONNX-compatible forward pass\n","    Uses fixed kernel size for pooling instead of adaptive pooling\n","    \"\"\"\n","    B, mel_bins, num_frames = input.size()\n","\n","    # Reshape\n","    x = input.view(B, model.in_channel, mel_bins // model.in_channel, num_frames)\n","\n","    # CNN encoder - this includes 4 ConvBlocks with pooling\n","    x = model.cnn(x)\n","\n","    # Pool frequency dimension using FIXED kernel size\n","    # This replaces F.adaptive_max_pool2d(x, (1, None))\n","    x = torch.nn.functional.max_pool2d(\n","        x,\n","        kernel_size=(freq_dim_after_cnn, 1)  # Use calculated size\n","    )\n","    x = x.squeeze(2)  # Remove frequency dimension\n","\n","    # BiLSTM\n","    output = model.bilstm(x)\n","\n","    return output\n","\n","original_forward = model.forward\n","\n","def export_forward_lightcnn(input):\n","    \"\"\"\n","    ONNX-compatible forward for LightweightHeartSoundCNN\n","    Consistent with training architecture\n","    \"\"\"\n","    B, F, T = input.size()\n","\n","    # (B, F, T) → (B, C, H, W)\n","    x = input.view(B, model.in_channel, F // model.in_channel, T)\n","\n","    # -------- Stem --------\n","    # stem = Conv2d + BN + ReLU6\n","    x = model.stem[0](x)   # Conv2d\n","    x = model.stem[1](x)   # BatchNorm\n","    x = model.stem[2](x)   # ReLU6\n","\n","    # -------- Feature blocks --------\n","    # Block 1\n","    x = model.features[0](x)   # DepthwiseSeparableConv(16 → 32)\n","    x = model.features[1](x)   # Dropout2d\n","\n","    # Block 2\n","    x = model.features[2](x)   # DepthwiseSeparableConv(32 → 64)\n","    x = model.features[3](x)   # Dropout2d\n","\n","    # Block 3\n","    x = model.features[4](x)   # DepthwiseSeparableConv(64 → 128)\n","    x = model.features[5](x)   # Dropout2d\n","\n","    # -------- Global Average Pooling --------\n","    x = model.pool(x)          # (B, 128, 1, 1)\n","    x = x.view(B, -1)          # (B, 128)\n","\n","    # -------- Classifier --------\n","    output = model.classifier(x)  # Không softmax (đúng chuẩn export / edge)\n","\n","    return output\n","\n","if MODEL_NAME == \"CNN\":\n","    model.forward = export_forward_simple_cnn\n","elif MODEL_NAME == \"VGG11\":\n","    model.forward = export_forward_vgg\n","elif MODEL_NAME == \"CRNN\":\n","    model.forward = export_forward_crnn\n","elif MODEL_NAME == \"Light_CNN\":\n","    model.forward = export_forward_lightcnn\n","else:\n","    raise ValueError(\"Unsupported model\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"Z320InRV3yFr","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1770136208651,"user_tz":-420,"elapsed":244,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"106015c3-64ff-48a9-b0c5-5b5b5a357266"},"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Export ONNX thành công: /content/drive/MyDrive/AutomaticHeartSoundClassification-main/TFLITE/light_cnn_0203_153447_final.onnx\n","Đã khôi phục forward gốc\n","Size: 0.05 MB\n"]}],"source":["\n","try:\n","    torch.onnx.export(\n","        model,\n","        dummy_input,\n","        str(ONNX_PATH),\n","        export_params=True,\n","        opset_version=17, #18\n","        do_constant_folding=True,\n","        input_names=[\"input\"],\n","        output_names=[\"output\"],\n","        dynamic_axes={\n","            \"input\": {0: \"batch_size\"},\n","            \"output\": {0: \"batch_size\"}\n","        },\n","        dynamo=False\n","        # verbose=False\n","    )\n","    print(f\"✅ Export ONNX thành công: {ONNX_PATH}\")\n","except Exception as e:\n","    print(\"Lỗi export:\", e)\n","finally:\n","    model.forward = original_forward\n","    print(\"Đã khôi phục forward gốc\")\n","\n","# Kiểm tra file\n","import os\n","if os.path.exists(ONNX_PATH):\n","    print(f\"Size: {os.path.getsize(ONNX_PATH) / (1024**2):.2f} MB\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"8hInr574Gvpg"},"outputs":[],"source":["'''\n","try:\n","    print(f\"📦 Exporting to: {ONNX_PATH.name}\\n\")\n","\n","    torch.onnx.export(\n","        model,\n","        dummy_input,\n","        str(ONNX_PATH),\n","\n","        export_params=True,\n","        opset_version=17,\n","        do_constant_folding=True,\n","\n","        input_names=[\"input\"],\n","        output_names=[\"output\"],\n","\n","        dynamic_axes={\n","     