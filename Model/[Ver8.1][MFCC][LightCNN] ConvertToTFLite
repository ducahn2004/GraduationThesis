ly pruning (với mask)\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"-i4lG_4VAxJn"},"outputs":[],"source":["import librosa\n","import random\n","import numpy as np\n","import torch\n","import torch.nn.functional as F\n","from torch.utils.data import Dataset, DataLoader\n","\n","EPS = 1e-8\n","\n","def standard_normal_variate(data):\n","    \"\"\"Z-score normalization trên toàn bộ feature\"\"\"\n","    mean = np.mean(data)\n","    std = np.std(data) + EPS\n","    return (data - mean) / std\n","\n","class MFCCDataset(Dataset):\n","    def __init__(self, features_h5_path, label_csv_path, keys=None,\n","                 norm=True, duration=5, hop_length=15, training=False):\n","        self.features_h5_path = features_h5_path\n","\n","        # Lấy keys từ đúng file này\n","        with h5py.File(features_h5_path, 'r') as hf:\n","            available_keys = set(hf.keys())\n","            if keys is None:\n","                self.keys = list(available_keys)\n","            else:\n","                # ✅ Chỉ giữ keys thực sự tồn tại trong file này\n","                self.keys = [k for k in keys if k in available_keys]\n","                dropped = len(keys) - len(self.keys)\n","                if dropped > 0:\n","                    print(f\"Bỏ {dropped} keys không tồn tại trong {features_h5_path.name}\")\n","\n","        self.labels_df = pd.read_csv(label_csv_path)\n","        self.key_to_label = dict(\n","            zip(self.labels_df.iloc[:, 0].apply(lambda x: Path(x).stem if '/' in str(x) else str(x)),\n","                self.labels_df.iloc[:, 1])\n","        )\n","        self.norm = norm\n","        self.training = training\n","        self.fixed_length = int(duration * 1000 / hop_length)\n","        self._hf = None\n","\n","    def _get_hf(self):\n","        if self._hf is None:\n","            self._hf = h5py.File(self.features_h5_path, 'r')\n","        return self._hf\n","\n","    def __len__(self):\n","        return len(self.keys)\n","\n","    def __getitem__(self, idx):\n","        key = self.keys[idx]\n","        mfcc = self._get_hf()[key][()].astype(np.float32)\n","\n","        if self.norm:\n","            mfcc = standard_normal_variate(mfcc)\n","\n","        n_mfcc, T = mfcc.shape\n","        if T >= self.fixed_length:\n","            start = (T - self.fixed_length) // 2\n","            mfcc = mfcc[:, start:start + self.fixed_length]\n","        else:\n","            mfcc = np.pad(mfcc, ((0, 0), (0, self.fixed_length - T)), mode=\"constant\")\n","\n","        return (\n","            torch.from_numpy(mfcc),\n","            torch.tensor(self.key_to_label.get(key, 0), dtype=torch.long)\n","        )\n","\n","    def close(self):\n","        if self._hf is not None:\n","            self._hf.close()\n","            self._hf = None"]},{"cell_type":"code","source":["import h5py\n","print(h5py.__version__)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"WjJ2ONv9SQG3","executionInfo":{"status":"ok","timestamp":1776352075744,"user_tz":-420,"elapsed":8,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"outputId":"b1a1a7b2-86a6-449d-d782-9afbef03558e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["3.11.0\n"]}]},{"cell_type":"code","execution_count":null,"metadata":{"id":"y_LClACDJrZE","executionInfo":{"status":"ok","timestamp":1776352083966,"user_tz":-420,"elapsed":8220,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"377047b8-3697-4503-c5d3-5722e9cc57c2"},"outputs":[{"output_type":"stream","name":"stdout","text":["Train: 4188 samples | Val: 266 samples\n"]}],"source":["TRAIN_H5  = DATASET_PATH / \"mfcc_train.h5\"\n","TRAIN_CSV = DATASET_PATH / \"label_train_augmented.csv\"\n","VAL_H5    = DATASET_PATH / \"mfcc_val_internal.h5\"\n","VAL_CSV   = DATASET_PATH / \"label_val_clean.csv\"\n","\n","train_dataset = MFCCDataset(TRAIN_H5, TRAIN_CSV, training=True)   # k