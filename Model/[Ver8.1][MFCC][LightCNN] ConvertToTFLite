ils):\n","    print(f\"Input {i}:\")\n","    print(f\"  Name        : {detail['name']}\")\n","    print(f\"  Shape       : {detail['shape']}\")\n","    print(f\"  Dtype       : {detail['dtype']}\")\n","    print(f\"  Quantization: {detail['quantization']}\")\n","\n","print(\"\\n=== THÔNG TIN OUTPUT ===\")\n","for detail in output_details:\n","    print(f\"  Shape       : {detail['shape']}\")\n","    print(f\"  Dtype       : {detail['dtype']}\")\n","    print(f\"  Quantization: {detail['quantization']}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"UKIlMv8Vetjy"},"outputs":[],"source":["import h5py\n","import pandas as pd\n","import numpy as np\n","import torch\n","from torch.utils.data import Dataset, DataLoader\n","import librosa\n","from pathlib import Path\n","\n","PROJECT_PATH = Path('/content/drive/MyDrive/AutomaticHeartSoundClassification-main')\n","DATASET_PATH = PROJECT_PATH / \"data\"\n","\n","features_file = DATASET_PATH / \"mfcc_val_internal.h5\"\n","label_file = DATASET_PATH / \"label_val_clean.csv\""]},{"cell_type":"code","execution_count":null,"metadata":{"id":"fgWDsV3devhM"},"outputs":[],"source":["import h5py\n","from torch.utils.data import DataLoader\n","\n","# ============================================================\n","# LOAD ALL KEYS FROM MFCC HDF5\n","# ============================================================\n","with h5py.File(features_file, 'r') as hf:\n","    all_keys = list(hf.keys())\n","\n","print(f\"Tổng số mẫu: {len(all_keys)}\")\n","\n","# ============================================================\n","# CREATE FULL DATASET FOR FINAL EVALUATION (MFCC)\n","# ============================================================\n","full_dataset = MFCCDataset(\n","    features_h5_path=features_file,\n","    label_csv_path=label_file,\n","    keys=all_keys,\n","    #use_delta=True,     # MFCC + Δ + Δ² → 39 coefficients\n","    norm=True,\n","    duration=5,\n","    hop_length=15,\n","    training=False      # không random crop (center crop)\n",")\n","\n","# ============================================================\n","# DATALOADER\n","# ============================================================\n","full_loader = DataLoader(\n","    full_dataset,\n","    batch_size=32,\n","    shuffle=False,\n","    num_workers=2,\n","    pin_memory=True\n",")\n","\n","print(\"✅ Đã tạo DataLoader MFCC thành công!\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"DewFVNZVex07"},"outputs":[],"source":["def test_tflite_accuracy(tflite_path, data_loader):\n","    interpreter = tf.lite.Interpreter(model_path=str(tflite_path))\n","    interpreter.allocate_tensors()\n","\n","    input_details = interpreter.get_input_details()\n","    output_details = interpreter.get_output_details()\n","\n","    _, time_steps, n_mfcc = input_details[0]['shape']\n","\n","    print(f\"Testing model: {tflite_path.name}\")\n","    print(f\"Expected input shape: (1,{n_mfcc}, {time_steps})\")\n","\n","    correct, total = 0, 0\n","    total_loss = 0.0\n","\n","    # Confusion matrix counts (binary: 0=normal, 1=abnormal)\n","    TP = TN = FP = FN = 0\n","\n","    for features, labels in data_loader:\n","        for i in range(features.shape[0]):\n","            x = features[i].numpy()\n","\n","            # Chuẩn hóa về (time, freq)\n","            if x.shape == (n_mfcc, time_steps):   # (39, 333)\n","                x = x.T                            # → (333, 39) ✅\n","            elif x.shape != (time_steps, n_mfcc):\n","                raise ValueError(f\"Shape mismatch: got {x.shape}, expected ({time_steps}, {n_mfcc})\")\n","\n","            # Quantize input nếu cần\n","            scale, zero_point = input_details[0]['quantization']\n","            if input_details[0]['dtype'] == np.int8:\n","                x_input = (x / scale + zero_point).astype(np.int8)\n","            else:\n","                x_input = x.astype(np.float32)\n","\n","            x_input = np.expand_dims(x_input, axis=0)\n","\n","            interpreter.set_tensor(input_details[0]['index'], x_input)\n","            interpreter.invoke()\n","\n","            out_detail = output_details[0]\n","            output = interpreter.get_tensor(out_detail['index'])\n","\n","            # Dequantize output nếu int8\n","            if out_detail['dtype'] == np.int8:\n","                out_scale, zp = out_detail['quantization']\n","                output = (output.astype(np.float32) - zp) * out_scale\n","\n","            # output shape: (1, num_classes) — raw logits\n","            logits = output[0].astype(np.float32)           # (num_classes,)\n","            gt = int(labels[i].item())\n","\n","            # ── Cross-entropy loss (from logits) ──────────────────────────\n","            exp_logits = np.exp(logits - np.max(logits))    # stable softmax\n","            probs = exp_logits / exp_logits.sum()\n","            loss = -np.log(probs[gt] + 1e-8)\n","            total_loss += loss\n","\n","            # ── Prediction ────────────────────────────────────────────────\n","            pred = int(np.argmax(logits))\n","\n","            if pred == gt:\n","                correct += 1\n","\n","            # ── Confusion matrix (1 = abnormal/positive) ──────────────────\n","            if gt == 1 and pred == 1:\n","                TP += 1\n","            elif gt == 0 and pred == 0:\n","                TN += 1\n","            elif gt == 0 and pred == 1:\n","                FP += 1\n","            elif gt == 1 and pred == 0:\n","                FN += 1\n","\n","            total += 1\n","\n","    # ── Metrics ───────────────────────────────────────────────────────────\n","    acc         = correct / total\n","    avg_loss    = total_loss / total\n","    sensitivity = TP / (TP + FN) if (TP + FN) > 0 else 0.0  # Recall / TPR\n","    specificity = TN / (TN + FP) if (TN + FP) > 0 else 0.0  # TNR\n","\n","    print(f\"\\n── Results: {tflite_path.name} ──\")\n","    print(f\"  Accuracy    : {acc*100:.2f}%  ({correct}/{total})\")\n","    print(f\"  Avg Loss    : {avg_loss:.4f}\")\n","    print(f\"  Sensitivity : {sensitivity*100:.2f}%  (TP={TP}, FN={FN})\")\n","    print(f\"  Specificity : {specificity*100:.2f}%  (TN={TN}, FP={FP})\")\n","\n","    return {\n","        \"accuracy\":    acc,\n","        \"loss\":        avg_loss,\n","        \"sensitivity\": sensitivity,\n","        \"specificity\": specificity,\n","        \"TP\": TP, \"TN\": TN, \"FP\": FP, \"FN\": FN\n","    }"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"9smgNBV3ezLq"},"outputs":[],"source":["from pathlib import Path\n","\n","# Tìm file INT8\n","tflite_files = list(OUTPUT_TFLITE_DIR.glob(\"*integer*.tflite\")) + list(OUTPUT_TFLITE_DIR.glob(\"*quant*.tflite\"))\n","if not tflite_files:\n","    raise FileNotFoundError(\"Không tìm thấy file TFLite INT8!\")\n","\n","int8_tflite_path = tflite_files[0]\n","print(f\"Đang test với: {int8_tflite_path.name}\")\n","\n","# Chạy test\n","test_tflite_accuracy(int8_tflite_path, full_loader)\n","\n","# Đóng dataset\n","full_dataset.close()"]},{"cell_type":"markdown","source":["## Validation"],"metadata":{"id":"my2fbISBfb7O"}},{"cell_type":"code","source":["PROJECT_PATH = Path('/content/drive/MyDrive/AutomaticHeartSoundClassification-main')\n","DATASET_PATH = PROJECT_PATH / \"data\"\n","\n","features_file = DATASET_PATH / \"mfcc_features_validation.h5\"\n","label_file = DATASET_PATH / \"label_validation.csv\""],"metadata":{"id":"6d3NNutcfSof"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import h5py\n","from torch.utils.data import DataLoader\n","\n","# ============================================================\n","# LOAD ALL KEYS FROM MFCC HDF5\n","# ============================================================\n","with h5py.File(features_file, 'r') as hf:\n","    all_keys = list(hf.keys())\n","\n","print(f\"Tổng số mẫu: {len(all_keys)}\")\n","\n","# ============================================================\n","# CREATE FULL D