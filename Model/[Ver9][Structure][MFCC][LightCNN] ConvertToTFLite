n","    \"\"\"\n","    Prune có cấu trúc: xóa filter yếu nhất theo L2 norm.\n","    - Bỏ qua Depthwise Conv (groups > 1) vì sẽ phá vỡ groups constraint\n","    - Chỉ prune Pointwise Conv và stem Conv\n","    \"\"\"\n","    pruned_layers = []\n","    skipped_layers = []\n","\n","    for name, module in model.named_modules():\n","        if isinstance(module, torch.nn.Conv2d):\n","            if module.groups > 1:\n","                skipped_layers.append(name)\n","                continue\n","\n","            prune.ln_structured(\n","                module,\n","                name='weight',\n","                amount=amount,\n","                n=2,    # L2 norm\n","                dim=0   # prune output channel (filter)\n","            )\n","            pruned_layers.append(name)\n","\n","    print(f\"✅ Pruned  : {len(pruned_layers)} lớp → {pruned_layers}\")\n","    print(f\"⏭️  Skipped : {len(skipped_layers)} lớp → {skipped_layers}\")\n","    return pruned_layers\n","\n","# ── Áp dụng ───────────────────────────────────────\n","parameters_to_prune = apply_structured_pruning_safe(model, amount=0.2)\n","print(\"✅ Đã apply structured pruning (với mask)\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"-i4lG_4VAxJn"},"outputs":[],"source":["import librosa\n","import random\n","import numpy as np\n","import torch\n","import torch.nn.functional as F\n","from torch.utils.data import Dataset, DataLoader\n","\n","EPS = 1e-8\n","\n","def standard_normal_variate(data):\n","    \"\"\"Z-score normalization trên toàn bộ feature\"\"\"\n","    mean = np.mean(data)\n","    std = np.std(data) + EPS\n","    return (data - mean) / std\n","\n","class MFCCDataset(Dataset):\n","    def __init__(self, features_h5_path, label_csv_path, keys=None,\n","                 norm=True, duration=5, hop_length=15, training=False):\n","        self.features_h5_path = features_h5_path\n","\n","        # Lấy keys từ đúng file này\n","        with h5py.File(features_h5_path, 'r') as hf:\n","            available_keys = set(hf.keys())\n","            if keys is None:\n","                self.keys = list(available_keys)\n","            else:\n","                # ✅ Chỉ giữ keys thực sự tồn tại trong file này\n","                self.keys = [k for k in keys if k in available_keys]\n","                dropped = len(keys) - len(self.keys)\n","                if dropped > 0:\n","                    print(f\"Bỏ {dropped} keys không tồn tại trong {features_h5_path.name}\")\n","\n","        self.labels_df = pd.read_csv(label_csv_path)\n","        self.key_to_label = dict(\n","            zip(self.labels_df.iloc[:, 0].apply(lambda x: Path(x).stem if '/' in str(x) else str(x)),\n","                self.labels_df.iloc[:, 1])\n","        )\n","        self.norm = norm\n","        self.training = training\n","        self.fixed_length = int(duration * 1000 / hop_length)\n","        self._hf = None\n","\n","    def _get_hf(self):\n","        if self._hf is None:\n","            self._hf = h5py.File(self.features_h5_path, 'r')\n","        return self._hf\n","\n","    def __len__(self):\n","        return len(self.keys)\n","\n","    def __getitem__(self, idx):\n","        key = self.keys[idx]\n","        mfcc = self._get_hf()[key][()].astype(np.float32)\n","\n","        if self.norm:\n","            mfcc = standard_normal_variate(mfcc)\n","\n","        n_mfcc, T = mfcc.shape\n","        if T >= self.fixed_length:\n","            start = (T - self.fixed_length) // 2\n","            mfcc = mfcc[:, start:start + self.fixed_length]\n","        else:\n","            mfcc = np.pad(mfcc, ((0, 0), (0, self.fixed_length - T)), mode=\"constant\")\n","\n","        return (\n","            torch.from_numpy(mfcc),\n","            torch.tensor(self.key_to_label.get(key, 0), dtype=torch.long)\n","        )\n","\n","    def close(self):\n","        if self._hf is not None:\n","            self._hf.close()\n","            self._hf = None"]},{"cell_type":"code","source":["import h