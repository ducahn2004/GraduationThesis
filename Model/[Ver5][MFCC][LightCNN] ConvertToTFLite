ze for pooling instead of adaptive pooling\n","    \"\"\"\n","    B, mel_bins, num_frames = input.size()\n","\n","    # Reshape\n","    x = input.view(B, model.in_channel, mel_bins // model.in_channel, num_frames)\n","\n","    # CNN encoder - this includes 4 ConvBlocks with pooling\n","    x = model.cnn(x)\n","\n","    # Pool frequency dimension using FIXED kernel size\n","    # This replaces F.adaptive_max_pool2d(x, (1, None))\n","    x = torch.nn.functional.max_pool2d(\n","        x,\n","        kernel_size=(freq_dim_after_cnn, 1)  # Use calculated size\n","    )\n","    x = x.squeeze(2)  # Remove frequency dimension\n","\n","    # BiLSTM\n","    output = model.bilstm(x)\n","\n","    return output\n","\n","original_forward = model.forward\n","\n","def export_forward_lightcnn(input):\n","    \"\"\"\n","    ONNX-compatible forward for LightweightHeartSoundCNN (Ver 8)\n","    \"\"\"\n","    B, CMel, T = input.size()\n","    # Chuyển (B, 39, 333) -> (B, 3, 13, 333)\n","    x = input.view(B, model.in_channel, CMel // model.in_channel, T)\n","\n","    x = model.stem(x)\n","    x = model.stage1(x)\n","    x = model.stage2(x)\n","    x = model.stage3(x)\n","    x = model.se(x)\n","    x = x * model.spatial_attn(x)\n","    x = x.mean(dim=[2, 3])\n","    output = model.classifier(x)\n","    return output\n","\n","if MODEL_NAME == \"CNN\":\n","    model.forward = export_forward_simple_cnn\n","elif MODEL_NAME == \"VGG11\":\n","    model.forward = export_forward_vgg\n","elif MODEL_NAME == \"CRNN\":\n","    model.forward = export_forward_crnn\n","elif MODEL_NAME == \"Light_CNN\":\n","    model.forward = export_forward_lightcnn\n","else:\n","    raise ValueError(\"Unsupported model\")"]},{"cell_type":"code","execution_count":52,"metadata":{"id":"Z320InRV3yFr","executionInfo":{"status":"ok","timestamp":1772296721755,"user_tz":-420,"elapsed":741,"user":{"displayName":"Ahn Đức","userId":"03706930103223800336"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"8aae226f-1e5