np.int8)\n","            elif in_dtype == np.uint8:\n","                x = np.clip(np.round(x / in_scale) + in_zp, 0, 255).astype(np.uint8)\n","            # float32: dùng thẳng, không cần làm gì\n","\n","            interpreter.set_tensor(input_details['index'], x)\n","            interpreter.invoke()\n","            output = interpreter.get_tensor(output_details['index'])  # shape (1, 2)\n","\n","            # Dequantize output nếu cần\n","            if out_dtype == np.int8:\n","                output = (output.astype(np.float32) - out_zp) * out_scale\n","            elif out_dtype == np.uint8:\n","                output = (output.astype(np.float32) - out_zp) * out_scale\n","            # float32: dùng thẳng\n","\n","            pred = int(np.argmax(output[0]))\n","            gt   = int(labels[i].item())\n","\n","            if pred == gt: correct += 1\n","            if   gt == 1 and pred == 1: TP += 1\n","            elif gt == 1 and pred == 0: FN += 1\n","            elif gt == 0 and pred == 0: TN += 1\n","            else:                       FP += 1\n","            total += 1\n","\n","    acc = correct / total\n","    sen = TP / (TP + FN) if (TP + FN) > 0 else 0\n","    spe = TN / (TN + FP) if (TN + FP) > 0 else 0\n","    print(f\"\\n  Accuracy    : {acc*100:.2f}%  ({correct}/{total})\")\n","    print(f\"  Sensitivity : {sen*100:.2f}%  (TP={TP}, FN={FN})\")\n","    print(f\"  Specificity : {spe*100:.2f}%  (TN={TN}, FP={FP})\")\n","    return {\"acc\": acc, \"sen\": sen, \"spe\": spe}"],"metadata":{"id":"z4dy_wzSfsB7"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import tensorflow as tf\n","\n","# 1. Ưu tiên tìm file integer chuẩn\n","target_files = list(OUTPUT_TFLITE_DIR.glob(\"*full_integer_quant.tflite\"))\n","if not target_files:\n","    target_files = list(OUTPUT_TFLITE_DIR.glob(\"*_quant_float32.tflite\"))\n","\n","model_to_test = target_files[0]\n","print(f\"🚀 Test với model: {model_to_test.name}\")\n","\n","# 2. KHỞI TẠO INT