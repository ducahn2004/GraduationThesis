T >= FIXED_LENGTH:\n","                start = (T - FIXED_LENGTH) // 2\n","                data = data[:, start:start + FIXED_LENGTH]\n","            else:\n","                data = np.pad(data, ((0, 0), (0, FIXED_LENGTH - T)), mode=\"constant\")\n","\n","            data = data[None, :, :].astype(np.float32)  # (1, 39, 333)\n","            yield [data]\n","\n","print(\"✅ Đã chuẩn bị representative dataset từ mfcc_features.h5\")\n","'''\n","def representative_data_gen():\n","    with h5py.File(CALIB_H5, 'r') as hf:   # mở 1 lần duy nhất\n","        keys = list(hf.keys())\n","        np.random.shuffle(keys)\n","        keys = keys[:300]\n","\n","        for key in keys:\n","            data = hf[key][()].astype(np.float32)   # (39, T)\n","\n","            # Z-score — giống MFCCDataset\n","            mean = np.mean(data)\n","            std  = np.std(data) + 1e-8\n","            data = (data - mean) / std\n","\n","            # Center-crop hoặc pad → (39, 333)\n","            n_mfcc, T = data.shape\n","            if T >= 333:\n","                start = (T - 333) // 2\n","                data  = data[:, start:start + 333]\n","            else:\n","                data  = np.pad(data, ((0, 0), (0, 333 - T)), mode='constant')\n","\n","            # Transpose → (1, 333, 39)\n","            x = np.expand_dims(data.T, 0).astype(np.float32)\n","            yield [x]"]},{"cell_type":"markdown","source":["## Test ONXX"],"metadata":{"id":"nNKh_Qqexxow"}},{"cell_type":"code","source":["import onnxruntime as ort\n","import numpy as np\n","import torch\n","\n","def test_onnx_accuracy(onnx_path, data_loader, name=\"Dataset\"):\n","    # Khởi tạo session với Provider là CPU\n","    session = ort.InferenceSession(str(onnx_path), providers=['CPUExecutionProvider'])\n","    input_name = session.get_inputs()[0].name\n","\n","    print(f\"\\n--- Đang kiểm tra ONNX: {name} ---\")\n","    print(f\"File: {onnx_path.name}\")\n","\n","    correct, total = 0, 0\n","    TP = TN = FP = FN = 0\n","\n","    for features, labels in data_loader:\n","        # features shape: (Batch, 39, 333)\n","        for i in range(features.shape[0]):\n","            # Lấy 1 mẫu và thêm dimension batch: (1, 39, 333)\n","            x = features[i].numpy()\n","\n","            # QUAN TRỌNG: Không dùng .T nếu mô hình PyTorch của bạn nhận (39, 333)\n","            x_input = np.expand_dims(x, axis=0).astype(np.float32)\n","\n","            # Chạy inference\n","            outputs = session.run(None, {input_name: x_input})\n","            logits = outputs[0][0] # Lấy kết quả mẫu đầu tiên trong batch\n","\n","            gt = int(labels[i].item())\n","            pred = int(np.argmax(logits))\n","\n","            if pred == gt:\n","                correct += 1\n","\n","            # Tính Confusion Matrix\n","            if gt == 1 and pred == 1: TP += 1\n","            elif gt == 0 and pred == 0: TN += 1\n","            elif gt == 0 and pred == 1: FP += 1\n","            elif gt == 1 and pred == 0: FN += 1\n","\n","            total += 1\n","\n","    acc = correct / total if total > 0 else 0\n","    sen = TP / (TP + FN) if (TP + FN) > 0 else 0\n","    spe = TN / (TN + FP) if (TN + FP) > 0 else 0\n","\n","    print(f\"Kết quả {name}:\")\n","    print(f\"  Accuracy    : {acc*100:.2f}%\")\n","    print(f\"  Sensitivity : {sen*100:.2f}% (TP={TP}, FN={FN})\")\n","    print(f\"  Specificity : {spe*100:.2f}% (TN={TN}, FP={FP})\")\n","\n","    return sen"],"metadata":{"id":"rDMMx7mexxUa"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 1. KHỞI TẠO DATALOADER CHO TẬP INTERNAL VALIDATION\n","# ============================================================\n","val_internal_path = DATASET_PATH / \"mfcc_39_val_internal.h5\"\n","val_internal_label = DATASET_PATH / \"label_39_val_clean.csv\"\n","\n","# Lấy danh sách keys từ file h5\n","with h5py.File(val_internal_path, 'r') as hf:\n","    val_internal_key