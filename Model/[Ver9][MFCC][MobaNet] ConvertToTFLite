"print(\"✅ Đã apply pruning (với mask)\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"-i4lG_4VAxJn"},"outputs":[],"source":["import librosa\n","import random\n","import numpy as np\n","import torch\n","import torch.nn.functional as F\n","from torch.utils.data import Dataset, DataLoader\n","\n","EPS = 1e-8\n","\n","def standard_normal_variate(data):\n","    \"\"\"Z-score normalization trên toàn bộ feature\"\"\"\n","    mean = np.mean(data)\n","    std = np.std(data) + EPS\n","    return (data - mean) / std\n","\n","class MFCCDataset(Dataset):\n","    def __init__(self, features_h5_path, label_csv_path, keys=None,\n","                 norm=True, duration=5, hop_length=15, training=False):\n","        self.features_h5_path = features_h5_path\n","        self.labels_df = pd.read_csv(label_csv_path)\n","\n","        # Tạo mapping để tra cứu nhãn nhanh\n","        self.key_to_label = dict(\n","            zip(self.labels_df.iloc[:, 0].apply(lambda x: Path(x).stem if '/' in str(x) else str(x)),\n","                self.labels_df.iloc[:, 1])\n","        )\n","\n","        with h5py.File(features_h5_path, 'r') as hf:\n","            available_keys = set(hf.keys())\n","            if keys is None:\n","                # Nếu không truyền keys, mặc định lấy hết\n","                self.keys = [k for k in available_keys if k in self.key_to_label]\n","            else:\n","                # Chỉ lấy những keys vừa tồn tại trong file H5 vừa có nhãn\n","                self.keys = [k for k in keys if k in available_keys and k in self.key_to_label]\n","\n","        self.norm = norm\n","        self.training = training\n","        self.fixed_length = int(duration * 1000 / hop_length)\n","        self._hf = None\n","\n","    def _get_hf(self):\n","        if self._hf is None:\n","            self._hf = h5py.File(self.features_h5_path, 'r')\n","        return self._hf\n","\n","    def __len__(self):\n","        return len(self.keys)\n","\n","    def __getitem__(self, idx):\n","        key = self.keys[idx]\n","        mfcc = self._get_hf()[key][()].astype(np.float32)\n","\n","        if self.norm:\n","            mfcc = standard_normal_variate(mfcc)\n","\n","        n_mfcc, T = mfcc.shape\n","        if T >= self.fixed_length:\n","            start = (T - self.fixed_length) // 2\n","            mfcc = mfcc[:, start:start + self.fixed_length]\n","        else:\n","            mfcc = np.pad(mfcc, ((0, 0), (0, self.fixed_length - T)), mode=\"constant\")\n","\n","        return (\n","            torch.from_numpy(mfcc),\n","            torch.tensor(self.key_to_label.get(key, 0), dtype=torch.long)\n","        )\n","\n","    def close(self):\n","        if self._hf is not None:\n","            self._hf.close()\n","            self._hf = None"]},{"cell_type":"code","source":["import h5py\n","print(h5py.__version__)"],"metadata":{"id":"WjJ2ONv9SQG3"},"execution_count":null,"outputs":[]},{"cell_type":"code","execution_count":null,"metadata":{"id":"y_LClACDJrZE"},"outputs":[],"source":["TRAIN_H5  = DATASET_PATH / \"mfcc_39_train.h5\"\n","TRAIN_CSV = DATASET_PATH / \"label_39_train_augmented.csv\"\n","VAL_H5    = DATASET_PATH / \"mfcc_39_val_internal.h5\"\n","VAL_CSV   = DATASET_PATH / \"label_39_val_clean.csv\"\n","\n","\n","# Đọc file label để phân loại keys\n","labels_df = pd.read_csv(TRAIN_CSV)\n","# Chuẩn hóa tên file (stem) để khớp với key trong H5\n","labels_df['stem'] = labels_df.iloc[:, 0].apply(lambda x: Path(x).stem)\n","\n","# Tách keys theo nhãn\n","keys_normal = labels_df[labels_df.iloc[:, 1] == 0]['stem'].values\n","keys_abnormal = labels_df[labels_df.iloc[:, 1] == 1]['stem'].values\n","\n","# Lấy số lượng mẫu bằng với số lượng của lớp ít hơn (thường là Abnormal)\n","num_samples_per_class = min(len(keys_normal), len(keys_abnormal))\n","\n","\n","balanced_normal = np.random.choice(keys_normal, num_samples_per_class, replace=False)\n","balanced_abnormal = np.random.choice(keys_abnormal, num_samples_per_class, replace=False)\n","\n","# Lấy mẫu ngẫu nhiên hoặc lấy đầu danh sách để cân bằng\n","balanced_keys = np.concatenate([balanced_normal, balanced_abnormal])\n","np.random.shuffle(balanced_keys) # Trộn đều nhãn\n","\n","train_dataset = MFCCDataset(TRAIN_H5, TRAIN_CSV, training=True)   # keys=None → tự lấy từ TRAIN_H5\n","val_dataset   = MFCCDataset(VAL_H5,   VAL_CSV,   training=False)  # keys=None → tự lấy từ VAL_H5\n","\n","print(f\"Train: {len(train_dataset)} samples | Val: {len(val_dataset)} samples\")\n","print(f\"Balanced: {num_samples_per_class} sample/case.  Total: {len(train_dataset)}\")\n","\n","train_loader = DataLoader(train_dataset, batch_size=64, shuffle=True,\n","                          num_workers=2, pin_memory=True)\n","val_loader   = DataLoader(val_dataset,   batch_size=64, shuffle=False,\n","                          num_workers=2, pin_memory=True)"]},{"cell_type":"code","source":["criterion = AsymmetricFocalLoss(\n","    gamma_pos=0.5,    # Giữ sensitivity cao cho lớp Abnormal\n","    gamma_neg=2.0,    # Phạt nặng False Positive (nhãn Normal bị đoán sai)\n","    label_smoothing=0.05\n",")"],"metadata":{"id":"XgC23eDybMd8"},"execution_count":null,"outputs":[]},{"cell_type":"code","execution_count":null,"metadata":{"id":"ZKkKmnOR5Pwt","colab":{"base_uri":"https://localhost:8080/"},"outputId":"7bdca749-e73b-4d38-ba04-843a11f29fa9"},"outputs":[{"output_type":"stream","name":"stdout","text":["Fine-tune Epoch 1/50 - Avg Loss: 0.104380\n","Fine-tune Epoch 2/50 - Avg Loss: 0.077702\n","Fine-tune Epoch 3/50 - Avg Loss: 0.066869\n","Fine-tune Epoch 4/50 - Avg Loss: nan\n","Fine-tune Epoch 5/50 - Avg Loss: nan\n","   >>> Val Accuracy sau epoch 5: 0.7948\n","Fine-tune Epoch 6/50 - Avg Loss: nan\n","Fine-tune Epoch 7/50 - Avg Loss: nan\n","Fine-tune Epoch 8/50 - Avg Loss: nan\n","Fine-tune Epoch 9/50 - Avg Loss: nan\n","Fine-tune Epoch 10/50 - Avg Loss: nan\n","   >>> Val Accuracy sau epoch 10: 0.7948\n","Fine-tune Epoch 11/50 - Avg Loss: nan\n","Fine-tune Epoch 12/50 - Avg Loss: n