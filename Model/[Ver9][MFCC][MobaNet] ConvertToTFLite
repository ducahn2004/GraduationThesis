ata":{"id":"S8qBq3iFGobl"},"outputs":[],"source":["import h5py\n","import numpy as np\n","import librosa\n","from pathlib import Path\n","\n","PROJECT_PATH = Path('/content/drive/MyDrive/AutomaticHeartSoundClassification-main')\n","DATASET_PATH = PROJECT_PATH / \"data\"\n","features_file = DATASET_PATH / \"mfcc_39_train.h5\""]},{"cell_type":"code","source":["def prepare_balanced_calibration_data(\n","    save_path: str = \"calib_data_balanced_max.npy\",\n","    seed: int = 42,\n",") -> np.ndarray:\n","    \"\"\"\n","    Tạo tập Calibration cân bằng, tối đa hóa số mẫu Abnormal.\n","\n","    Chiến lược:\n","        1. Đọc toàn bộ nhãn từ TRAIN_CSV.\n","        2. Lấy TẤT CẢ khóa Abnormal (label == 1) tồn tại trong TRAIN_H5.\n","        3. Lấy đúng bằng số đó từ lớp Normal (label == 0), chọn ngẫu nhiên.\n","        4. Trộn, xử lý MFCC, lưu file .npy.\n","\n","    Parameters\n","    ----------\n","    save_path : str\n","        Đường dẫn lưu file .npy kết quả.\n","    seed : int\n","        Random seed để kết quả tái lập được.\n","\n","    Returns\n","    -------\n","    calibration_data : np.ndarray, shape (N, 39, 333)\n","    \"\"\"\n","    rng = np.random.default_rng(seed)\n","\n","    # ── 1. Đọc nhãn ──────────────────────────────────────────────────────────\n","    labels_df = pd.read_csv(TRAIN_CSV)\n","    labels_df['stem'] = labels_df.iloc[:, 0].apply(lambda x: Path(x).stem)\n","\n","    keys_normal   = labels_df[labels_df.iloc[:, 1] == 0]['stem'].values\n","    keys_abnormal = labels_df[labels_df.iloc[:, 1] == 1]['stem'].values\n","\n","    print(f\"📊 Thống kê CSV:\")\n","    print(f\"   Tổng Normal   : {len(keys_normal)}\")\n","    print(f\"   Tổng Abnormal : {len(keys_abnormal)}\")\n","\n","    # ── 2. Lọc chỉ lấy keys thực sự tồn tại trong H5 ────────────────────────\n","    with h5py.File(TRAIN_H5, 'r') as hf:\n","        h5_keys = set(hf.keys())\n","\n","    keys_abnormal_valid = np.array([k for k in keys_abnormal if k in h5_keys])\n","    keys_normal_valid   = np.array([k for k in keys_normal   if k in h5_keys])\n","\n","    n_abnormal = len(keys_abnormal_valid)\n","    n_normal   = len(keys_normal_valid)\n","\n","    print(f\"\\n Có trong H5:\")\n","    print(f\"   Normal   : {n_normal}\")\n","    print(f\"   Abnormal : {n_abnormal}  ← sẽ dùng toàn bộ\")\n","\n","    if n_normal < n_abnormal:\n","        print(f\"Normal ({n_normal}) ít hơn Abnormal ({n_abnormal}).\")\n","        print(f\"   Sẽ lấy tất cả Normal và {n_normal} Abnormal để cân bằng.\")\n","        n_use = n_normal\n","        calib_abnormal = rng.choice(keys_abnormal_valid, size=n_use, replace=False)\n","        calib_normal   = keys_normal_valid\n","    else:\n","        # Trường hợp thông thường: Normal nhiều hơn\n","        n_use = n_abnormal\n","        calib_abnormal = keys_abnormal_valid                          # lấy hết\n","        calib_normal   = rng.choice(keys_normal_valid, size=n_use, replace=False)\n","\n","    print(f\"\\n Số mẫu sử dụng: {n_use} Normal + {n_use} Abnormal = {n_use * 2} mẫu\")\n","\n","    # ── 3. Trộn ngẫu nhiên ───────────────────────────────────────────────────\n","    final_keys = list(calib_normal) + list(calib_abnormal)\n","    rng.shuffle(final_keys)\n","\n","    # ── 4. Đọc & xử lý MFCC ─────────────────────────────────────────────────\n","    calib_data_list = []\n","    skipped = 0\n","    total = len(final_keys)\n","\n","\n","    with h5py.File(TRAIN_H5, 'r') as hf:\n","        for i, key in enumerate(final_keys):\n","            if key not in hf:\n","                skipped += 1\n","                continue\n","\n","            feature = hf[key][()].astype(np.float32)      # (39, T)\n","\n","            # Z-score chuẩn hóa\n","            feature = standard_normal_variate(feature)\n","\n","            # Center-crop hoặc zero-pad về FIXED_LENGTH (333)\n","            T_len = feature.shape[1]\n","            if T_len >= FIXED_LENGTH:\n","                start   = (T_len - FIXED_LENGTH) // 2\n","               